{%- comment -%} medal | shipping | calendar {%- endcomment -%}
{%- case icon -%}
  {%- when 'medal' -%}
    <svg class="testimonial-split__fact-icon-svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.35" aria-hidden="true">
      <circle cx="24" cy="24" r="21"/>
      <circle cx="24" cy="18" r="7"/>
      <path d="M17 25l-4 12 7-4 7 4-4-12" stroke-linejoin="round"/>
    </svg>
  {%- when 'shipping' -%}
    <svg class="testimonial-split__fact-icon-svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.35" aria-hidden="true">
      <circle cx="24" cy="24" r="21"/>
      <path d="M14 20h22v14H14z" stroke-linejoin="round"/>
      <path d="M14 20V14h8v6"/>
      <circle cx="32" cy="34" r="2.5"/>
      <path d="M27 34H18"/>
      <circle cx="18" cy="34" r="2.5"/>
    </svg>
  {%- when 'calendar' -%}
    <svg class="testimonial-split__fact-icon-svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.35" aria-hidden="true">
      <circle cx="24" cy="24" r="21"/>
      <rect x="14" y="16" width="20" height="18" rx="2" stroke-linejoin="round"/>
      <path d="M14 22h20"/>
      <path d="M18 12v4M30 12v4"/>
      <path d="M22 30l3 3 5-6" stroke-linejoin="round"/>
    </svg>
  {%- else -%}
    <svg class="testimonial-split__fact-icon-svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.35" aria-hidden="true">
      <circle cx="24" cy="24" r="21"/>
    </svg>
{%- endcase -%}

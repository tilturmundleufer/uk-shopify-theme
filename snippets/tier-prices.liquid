{%- comment -%}
  Tier Prices Component
  
  Accepts:
  - product: {Object} Product Liquid object
  - class: {String} Additional CSS classes
  
  Expected Metafield Format (product.metafields.custom.tier_prices):
  JSON array: [{"qty": 40, "price": "11.59"}, {"qty": 80, "price": "11.25"}]
{%- endcomment -%}

{%- liquid
  assign tier_prices_json = product.metafields.custom.tier_prices
  assign has_tier_prices = false
  
  if tier_prices_json != blank
    assign has_tier_prices = true
  endif
-%}

{%- if has_tier_prices -%}
  <div class="tier-prices{% if class %} {{ class }}{% endif %}">
    <h4 class="tier-prices__title">{{ 'products.product.tier_prices' | t }}</h4>
    <table class="tier-prices__table">
      <tbody>
        {%- assign tier_prices = tier_prices_json.value -%}
        {%- for tier in tier_prices -%}
          <tr class="tier-prices__row">
            <td class="tier-prices__qty">
              {{ 'products.product.from_pieces' | t: count: tier.qty }}
            </td>
            <td class="tier-prices__price">
              {{ tier.price }}€
            </td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  </div>
{%- endif -%}

<style>
  .tier-prices {
    margin: 18px 0 20px;
    padding: 16px 18px;
    background:
      linear-gradient(180deg, rgba(var(--color-primary-rgb), 0.08) 0%, rgba(var(--color-primary-rgb), 0.03) 100%);
    border: 1px solid rgba(var(--color-primary-rgb), 0.2);
    border-radius: 16px;
  }
  
  .tier-prices__title {
    font-size: 0.84rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-secondary);
    margin-bottom: 10px;
  }
  
  .tier-prices__table {
    width: 100%;
    border-collapse: collapse;
  }
  
  .tier-prices__row {
    border-bottom: 1px solid var(--color-border);
  }
  
  .tier-prices__row:last-child {
    border-bottom: none;
  }
  
  .tier-prices__qty,
  .tier-prices__price {
    padding: 8px 0;
    font-size: var(--font-size-sm);
  }
  
  .tier-prices__qty {
    color: var(--color-ink-soft);
  }
  
  .tier-prices__price {
    font-weight: 700;
    color: var(--color-secondary);
    text-align: right;
  }
</style>

{%- comment -%}
  Product Tabs Component
  Description, Shipping, optional Datenblatt (PDF), optional Downloads
  
  Datenblatt: Produkt-Metafeld `custom.datasheet` (Datei) oder `custom.datasheet_pdf` / `custom.datasheet_url` (URL)
  
  Accepts:
  - product: {Object} Product Liquid object
  - skip_description_tab: {Boolean} If true, description is omitted (e.g. shown in the product column)
{%- endcomment -%}

{%- liquid
  assign skip_description_tab = skip_description_tab | default: false
  assign downloads_json = product.metafields.custom.downloads
  assign has_downloads = false
  if downloads_json != blank
    assign has_downloads = true
  endif

  assign has_datasheet = false
  assign datasheet_href = ''
  assign datasheet_btn_label = 'products.product.datasheet_open_pdf' | t

  assign ds_file = product.metafields.custom.datasheet
  if ds_file != blank and ds_file.value != blank and ds_file.value.url != blank
    assign datasheet_href = ds_file.value.url
    assign has_datasheet = true
  endif

  if has_datasheet == false
    assign ds_alt = product.metafields.custom.datasheet_pdf
    if ds_alt != blank and ds_alt.value != blank and ds_alt.value.url != blank
      assign datasheet_href = ds_alt.value.url
      assign has_datasheet = true
    endif
  endif

  if has_datasheet == false
    assign ds_link = product.metafields.custom.datasheet_url
    if ds_link != blank
      assign datasheet_href = ds_link.value | default: ds_link | strip
      if datasheet_href != blank
        assign has_datasheet = true
      endif
    endif
  endif

  assign ds_title_mf = product.metafields.custom.datasheet_title
  if ds_title_mf != blank and ds_title_mf.value != blank
    assign datasheet_btn_label = ds_title_mf.value | strip
  endif
-%}

{%- comment -%} Desktop Tabs {%- endcomment -%}
<div class="product-tabs tabs" data-tabs>
  <div class="tabs__list" role="tablist">
    {%- unless skip_description_tab -%}
      <button 
        class="tabs__btn" 
        role="tab" 
        aria-selected="true" 
        aria-controls="tab-description"
        id="tab-btn-description"
        data-tab-btn
      >
        {{ 'products.product.description' | t }}
      </button>
    {%- endunless -%}
    <button 
      class="tabs__btn" 
      role="tab" 
      aria-selected="{% if skip_description_tab %}true{% else %}false{% endif %}" 
      aria-controls="tab-shipping"
      id="tab-btn-shipping"
      data-tab-btn
    >
      {{ 'products.product.shipping' | t }}
    </button>
    {%- if has_datasheet -%}
      <button 
        class="tabs__btn" 
        role="tab" 
        aria-selected="false" 
        aria-controls="tab-datasheet"
        id="tab-btn-datasheet"
        data-tab-btn
      >
        {{ 'products.product.datasheet_tab' | t }}
      </button>
    {%- endif -%}
    {%- if has_downloads -%}
      <button 
        class="tabs__btn" 
        role="tab" 
        aria-selected="false" 
        aria-controls="tab-downloads"
        id="tab-btn-downloads"
        data-tab-btn
      >
        {{ 'products.product.downloads' | t }}
      </button>
    {%- endif -%}
  </div>
  
  {%- unless skip_description_tab -%}
    <div 
      class="tabs__panel" 
      role="tabpanel" 
      id="tab-description"
      aria-labelledby="tab-btn-description"
      data-tab-panel
    >
      <div class="tabs__panel-content rte product-tabs__description">
        {%- if product.description != blank -%}
          <h2 class="product-tabs__description-heading">{{ 'products.product.article_info_heading' | t }}</h2>
          {{ product.description }}
        {%- else -%}
          <p>{{ 'products.product.no_description' | t | default: 'Keine Beschreibung verfügbar.' }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endunless -%}
  
  <div 
    class="tabs__panel" 
    role="tabpanel" 
    id="tab-shipping"
    aria-labelledby="tab-btn-shipping"
    {% unless skip_description_tab %}hidden{% endunless %}
    data-tab-panel
  >
    <div class="tabs__panel-content rte">
      {%- if settings.shipping_info != blank -%}
        {{ settings.shipping_info }}
      {%- else -%}
        <p>Wir versenden unsere Produkte standardmäßig per Spedition inklusive telefonischer Avisierung.</p>
      {%- endif -%}
    </div>
  </div>

  {%- if has_datasheet -%}
    <div 
      class="tabs__panel" 
      role="tabpanel" 
      id="tab-datasheet"
      aria-labelledby="tab-btn-datasheet"
      hidden
      data-tab-panel
    >
      <div class="tabs__panel-content">
        <p class="product-tabs__datasheet-lead">
          <a href="{{ datasheet_href }}" class="btn btn--secondary product-tabs__datasheet-link" target="_blank" rel="noopener">
            {%- render 'icon-download' -%}
            {{ datasheet_btn_label }}
          </a>
        </p>
      </div>
    </div>
  {%- endif -%}
  
  {%- if has_downloads -%}
    <div 
      class="tabs__panel" 
      role="tabpanel" 
      id="tab-downloads"
      aria-labelledby="tab-btn-downloads"
      hidden
      data-tab-panel
    >
      <div class="tabs__panel-content">
        <div class="downloads-list">
          {%- assign downloads = downloads_json.value -%}
          {%- for download in downloads -%}
            <a href="{{ download.url }}" class="btn btn--secondary btn--sm downloads-list__item" target="_blank" rel="noopener">
              {%- render 'icon-download' -%}
              {{ download.title }}
            </a>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

{%- comment -%} Mobile Accordion {%- endcomment -%}
<div class="product-accordion accordion accordion--minimal" data-accordion>
  {%- unless skip_description_tab -%}
    <div class="accordion__item">
      <button 
        class="accordion__header" 
        aria-expanded="true"
        aria-controls="accordion-description"
        data-accordion-header
      >
      {{ 'products.product.description' | t }}
      <span class="accordion__icon">{%- render 'icon-chevron' -%}</span>
    </button>
    <div class="accordion__content" id="accordion-description" aria-hidden="false" data-accordion-content>
      <div class="accordion__inner">
        <div class="accordion__body rte product-tabs__description">
          {%- if product.description != blank -%}
            <h2 class="product-tabs__description-heading">{{ 'products.product.article_info_heading' | t }}</h2>
            {{ product.description }}
          {%- else -%}
            <p>Keine Beschreibung verfügbar.</p>
          {%- endif -%}
        </div>
      </div>
    </div>
    </div>
  {%- endunless -%}
  
  <div class="accordion__item">
    <button 
      class="accordion__header" 
      aria-expanded="{% if skip_description_tab %}true{% else %}false{% endif %}"
      aria-controls="accordion-shipping"
      data-accordion-header
    >
      {{ 'products.product.shipping' | t }}
      <span class="accordion__icon">{%- render 'icon-chevron' -%}</span>
    </button>
    <div class="accordion__content" id="accordion-shipping" aria-hidden="{% if skip_description_tab %}false{% else %}true{% endif %}" data-accordion-content>
      <div class="accordion__inner">
        <div class="accordion__body rte">
          {%- if settings.shipping_info != blank -%}
            {{ settings.shipping_info }}
          {%- else -%}
            <p>Wir versenden unsere Produkte standardmäßig per Spedition inklusive telefonischer Avisierung.</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- if has_datasheet -%}
    <div class="accordion__item">
      <button 
        class="accordion__header" 
        aria-expanded="false"
        aria-controls="accordion-datasheet"
        data-accordion-header
      >
        {{ 'products.product.datasheet_tab' | t }}
        <span class="accordion__icon">{%- render 'icon-chevron' -%}</span>
      </button>
      <div class="accordion__content" id="accordion-datasheet" aria-hidden="true" data-accordion-content>
        <div class="accordion__inner">
          <div class="accordion__body">
            <p class="product-tabs__datasheet-lead">
              <a href="{{ datasheet_href }}" class="btn btn--secondary product-tabs__datasheet-link" target="_blank" rel="noopener">
                {%- render 'icon-download' -%}
                {{ datasheet_btn_label }}
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
  
  {%- if has_downloads -%}
    <div class="accordion__item">
      <button 
        class="accordion__header" 
        aria-expanded="false"
        aria-controls="accordion-downloads"
        data-accordion-header
      >
        {{ 'products.product.downloads' | t }}
        <span class="accordion__icon">{%- render 'icon-chevron' -%}</span>
      </button>
      <div class="accordion__content" id="accordion-downloads" aria-hidden="true" data-accordion-content>
        <div class="accordion__inner">
          <div class="accordion__body">
            <div class="downloads-list">
              {%- assign downloads = downloads_json.value -%}
              {%- for download in downloads -%}
                <a href="{{ download.url }}" class="btn btn--secondary btn--sm downloads-list__item" target="_blank" rel="noopener">
                  {%- render 'icon-download' -%}
                  {{ download.title }}
                </a>
              {%- endfor -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

<style>
  .downloads-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .downloads-list__item {
    min-width: 0;
  }
  
  .downloads-list__item svg {
    width: 16px;
    height: 16px;
    margin-right: var(--spacing-xs);
  }

  .product-tabs__description-heading {
    font-size: var(--font-size-md);
    font-weight: 800;
    margin: 0 0 12px;
    color: var(--color-text);
  }

  .product-tabs__description.rte > p:first-of-type {
    margin-top: 0;
  }

  .product-tabs__datasheet-lead {
    margin: 0;
  }

  .product-tabs__datasheet-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .product-tabs__datasheet-link svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
</style>

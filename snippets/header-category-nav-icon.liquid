{%- comment -%}
  Icon für die gelbe Kategorien-Leiste: optionales Bild aus Header-Block „Kategorie-Icon“,
  sonst die eingebauten SVGs (inkl. Kreis als Fallback).
{%- endcomment -%}
{%- liquid
  assign nav_custom_icon = blank
  assign link_handle_cmp = link.handle | strip | downcase
  assign link_title_cmp = link.title | strip | downcase
  for block in section.blocks
    if block.type == 'nav_icon' and block.settings.icon != blank
      assign bh = block.settings.menu_handle | strip | downcase
      assign bt = block.settings.menu_title | strip | downcase
      if bh != blank and bh == link_handle_cmp
        assign nav_custom_icon = block.settings.icon
        break
      endif
      if bt != blank and bt == link_title_cmp
        assign nav_custom_icon = block.settings.icon
        break
      endif
    endif
  endfor
-%}
{%- if nav_custom_icon != blank -%}
  <img
    src="{{ nav_custom_icon | image_url: width: 40 }}"
    alt=""
    class="header__nav-icon header__nav-icon--custom"
    width="20"
    height="20"
    loading="eager"
    decoding="async"
  >
{%- else -%}
  {%- case link.title | downcase -%}
    {%- when 'unterkonstruktion' -%}
      <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
    {%- when 'solarmodule' -%}
      <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    {%- when 'wechselrichter' -%}
      <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="7" width="20" height="10" rx="2"/><line x1="6" y1="12" x2="10" y2="12"/><circle cx="16" cy="12" r="2"/></svg>
    {%- when 'batteriespeicher' -%}
      <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="7" width="18" height="10" rx="2"/><line x1="22" y1="11" x2="22" y2="13"/><line x1="6" y1="11" x2="6" y2="13"/><line x1="10" y1="11" x2="10" y2="13"/><line x1="14" y1="11" x2="14" y2="13"/></svg>
    {%- when 'zubehör' -%}
      <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
    {%- else -%}
      <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/></svg>
  {%- endcase -%}
{%- endif -%}

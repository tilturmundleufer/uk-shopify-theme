{%- comment -%}
  Product Card Component
  
  Accepts:
  - product: {Object} Product Liquid object
  - show_qty_stepper: {Boolean} Show quantity stepper (default: true)
  - lazy_load: {Boolean} Lazy load images (default: true)
  - show_vendor: {Boolean} Show vendor (default: false)
  - show_description: {Boolean} Show short description (default: true)
  - card_class: {String} Additional CSS classes
{%- endcomment -%}

{%- liquid
  assign show_qty_stepper = show_qty_stepper | default: true
  assign lazy_load = lazy_load | default: true
  assign show_vendor = show_vendor | default: false
  assign show_description = show_description | default: true
  
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = product.featured_image
  
  assign is_on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign is_on_sale = true
  endif
  
  assign is_sold_out = false
  unless current_variant.available
    assign is_sold_out = true
  endunless
  
  assign unit_price = product.metafields.custom.unit_price
  assign unit_label = product.metafields.custom.unit_label | default: '/ Stück'
-%}

<div class="product-card{% if is_sold_out %} product-card--sold-out{% endif %}{% if card_class %} {{ card_class }}{% endif %}" data-product-card data-product-id="{{ product.id }}">
  {%- comment -%} Image {%- endcomment -%}
  <div class="product-card__image-wrapper badge-container">
    {%- if featured_image -%}
      <img
        src="{{ featured_image | image_url: width: 600 }}"
        srcset="
          {{ featured_image | image_url: width: 300 }} 300w,
          {{ featured_image | image_url: width: 450 }} 450w,
          {{ featured_image | image_url: width: 600 }} 600w
        "
        sizes="(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw"
        alt="{{ featured_image.alt | escape | default: product.title }}"
        class="product-card__image"
        width="{{ featured_image.width }}"
        height="{{ featured_image.height }}"
        {% if lazy_load %}loading="lazy"{% endif %}
      >
    {%- else -%}
      <div class="product-card__image product-card__image--placeholder">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {%- endif -%}
    
    {%- comment -%} Badges {%- endcomment -%}
    <div class="product-card__badges">
      {%- render 'stock-badge', product: product, variant: current_variant -%}
      {%- if is_on_sale -%}
        <span class="badge badge--sale">{{ 'products.product.on_sale' | t }}</span>
      {%- endif -%}
    </div>
  </div>
  
  {%- comment -%} Content {%- endcomment -%}
  <div class="product-card__content">
    {%- if show_vendor and product.vendor -%}
      <p class="product-card__vendor">{{ product.vendor }}</p>
    {%- endif -%}
    
    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    
    {%- if show_description -%}
      {%- assign short_description = product.metafields.custom.short_subtitle | default: product.description | strip_html | truncate: 80 -%}
      {%- if short_description != blank -%}
        <p class="product-card__description">{{ short_description }}</p>
      {%- endif -%}
    {%- endif -%}
    
    {%- comment -%} Price {%- endcomment -%}
    <div class="product-card__price-wrapper">
      {%- if is_on_sale -%}
        <span class="product-card__price product-card__price--compare">
          {{ current_variant.compare_at_price | money }}
        </span>
      {%- endif -%}
      <span class="product-card__price{% if is_on_sale %} product-card__price--sale{% endif %}">
        {{ current_variant.price | money }}
      </span>
      {%- if unit_price != blank or unit_label != blank -%}
        <span class="product-card__price-unit">
          ({% if unit_price != blank %}{{ unit_price }}{% else %}{{ current_variant.price | money }}{% endif %}{{ unit_label }})
        </span>
      {%- endif -%}
    </div>
    
    {%- comment -%} Actions {%- endcomment -%}
    <div class="product-card__actions">
      {%- if show_qty_stepper and current_variant.available -%}
        <div class="product-card__qty-row">
          <span class="product-card__qty-label">{{ 'products.product.quantity' | t }}</span>
          {%- render 'qty-stepper', variant: current_variant, size: 'compact', form_id: product.id -%}
        </div>
      {%- endif -%}
      
      <product-form class="product-card__form" data-product-form>
        <form action="{{ routes.cart_add_url }}" method="post" id="product-form-{{ product.id }}">
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          <input type="hidden" name="quantity" value="1" class="product-card__qty-input" data-qty-input>
          
          <button 
            type="submit" 
            class="btn btn--primary btn--full product-card__add-btn"
            {% unless current_variant.available %}disabled{% endunless %}
            data-add-to-cart
          >
            {%- if current_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>
        </form>
      </product-form>
    </div>
  </div>
  
  {%- comment -%} Success/Error Message {%- endcomment -%}
  <div class="product-card__message" data-card-message aria-live="polite"></div>
</div>

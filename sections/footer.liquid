{%- comment -%}
  Footer: Streifen Logo/Kontakt, CTA, Menüs, Bezahlung, Legal
{%- endcomment -%}

{%- liquid
  assign logo = section.settings.logo
  assign show_payment_icons = section.settings.show_payment_icons
  assign cta_heading = section.settings.cta_heading
  assign cta_button_text = section.settings.cta_button_text
  assign cta_button_url = section.settings.cta_button_url

  for block in section.blocks
    if block.type == 'cta'
      assign cta_heading = block.settings.heading
      assign cta_button_text = block.settings.button_text
      assign cta_button_url = block.settings.button_url
      break
    endif
  endfor
-%}

<footer class="footer footer--uk">
  <div class="footer__strip">
    <div class="page-width footer__strip-inner">
      <div class="footer__strip-logo">
        {%- if logo != blank -%}
          <img
            src="{{ logo | image_url: width: 200 }}"
            alt="{{ shop.name }}"
            class="footer__strip-logo-img"
            width="140"
            height="{{ 140 | divided_by: logo.aspect_ratio | round }}"
            loading="lazy"
          >
        {%- else -%}
          <span class="footer__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </div>
      <div class="footer__strip-contact">
        {%- if settings.contact_phone != blank -%}
          <a href="tel:{{ settings.contact_phone | remove: ' ' }}" class="footer__strip-link">
            {%- render 'icon-phone' -%}
            <span>{{ settings.contact_phone }}</span>
          </a>
        {%- endif -%}
        {%- if settings.contact_email != blank -%}
          <a href="mailto:{{ settings.contact_email }}" class="footer__strip-link">
            {%- render 'icon-mail' -%}
            <span>{{ settings.contact_email }}</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="footer__body">
    <div class="page-width footer__body-grid">
      <div class="footer__cta-block">
        {%- if cta_heading != blank -%}
          <h2 class="footer__cta-heading">{{ cta_heading }}</h2>
        {%- endif -%}
        {%- if cta_button_text != blank and cta_button_url != blank -%}
          <a href="{{ cta_button_url }}" class="footer__cta-link">
            <span class="footer__cta-square" aria-hidden="true">
              {%- render 'icon-arrow-up-right', class: 'footer__cta-arrow' -%}
            </span>
            <span class="footer__cta-link-text">{{ cta_button_text }}</span>
          </a>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <div class="footer__col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__col-title">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer__col-list" role="list">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li>
                      <a href="{{ link.url }}" class="footer__col-link">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'payment_column' -%}
            <div class="footer__col footer__col--payment" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__col-title">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if show_payment_icons -%}
                <div class="footer__payment-grid">
                  {%- for type in shop.enabled_payment_types -%}
                    <span class="footer__payment-cell">
                      {{ type | payment_type_svg_tag }}
                    </span>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="footer__bottom">
    <div class="page-width footer__bottom-inner">
      <div class="footer__legal">
        {%- for block in section.blocks -%}
          {%- if block.type == 'legal_link' -%}
            <a href="{{ block.settings.link }}" class="footer__bottom-link" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- if section.settings.credit_text != blank -%}
        <p class="footer__credit">
          {%- if section.settings.credit_url != blank -%}
            <a href="{{ section.settings.credit_url }}" class="footer__credit-link" target="_blank" rel="noopener">
              {{ section.settings.credit_text }}
              {%- render 'icon-arrow', class: 'footer__credit-ico' -%}
            </a>
          {%- else -%}
            {{ section.settings.credit_text }}
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (oberer Streifen)"
    },
    {
      "type": "header",
      "content": "CTA-Spalte"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "Überschrift",
      "default": "Sie haben Fragen? Unser Team hilft Ihnen gerne weiter!"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "Button-Text",
      "default": "Jetzt kontaktieren"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "Button-Link"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Zahlungsarten (Spalte „Bezahlung“)",
      "default": true
    },
    {
      "type": "header",
      "content": "Credit"
    },
    {
      "type": "text",
      "id": "credit_text",
      "label": "Website-Credit",
      "default": "Website by Turm & Leufer"
    },
    {
      "type": "url",
      "id": "credit_url",
      "label": "Credit-Link (optional)"
    }
  ],
  "blocks": [
    {
      "type": "cta",
      "name": "CTA-Block (Legacy)",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Sie haben Fragen? Unser Team hilft Ihnen gerne weiter!"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button-Text",
          "default": "Jetzt kontaktieren"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button-Link"
        }
      ]
    },
    {
      "type": "menu",
      "name": "Menü-Spalte",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Kategorien"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menü"
        }
      ]
    },
    {
      "type": "payment_column",
      "name": "Bezahlung",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Bezahlung"
        }
      ]
    },
    {
      "type": "legal_link",
      "name": "Rechtlicher Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Text",
          "default": "Datenschutz"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "settings": {
        "cta_heading": "Sie haben Fragen? Unser Team hilft Ihnen gerne weiter!",
        "cta_button_text": "Jetzt kontaktieren",
        "credit_text": "Website by Turm & Leufer"
      },
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "heading": "Kategorien"
          }
        },
        {
          "type": "menu",
          "settings": {
            "heading": "Navigation"
          }
        },
        {
          "type": "payment_column",
          "settings": {
            "heading": "Bezahlung"
          }
        },
        {
          "type": "legal_link",
          "settings": {
            "label": "Datenschutz"
          }
        },
        {
          "type": "legal_link",
          "settings": {
            "label": "Impressum"
          }
        }
      ]
    }
  ]
}
{% endschema %}

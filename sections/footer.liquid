{%- comment -%}
  Footer Section
{%- endcomment -%}

{%- liquid
  assign logo = section.settings.logo
  assign show_payment_icons = section.settings.show_payment_icons
-%}

<footer class="footer">
  <div class="page-width">
    <div class="footer__top">
      {%- comment -%} Brand Column {%- endcomment -%}
      <div class="footer__brand">
        <div class="footer__logo">
          {%- if logo != blank -%}
            <img
              src="{{ logo | image_url: width: 240 }}"
              alt="{{ shop.name }}"
              class="footer__logo-img"
              width="120"
              loading="lazy"
            >
          {%- else -%}
            <span class="footer__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </div>
        
        <div class="footer__contact">
          {%- if settings.contact_phone != blank -%}
            <a href="tel:{{ settings.contact_phone | remove: ' ' }}" class="footer__contact-link">
              {%- render 'icon-phone' -%}
              <span>{{ settings.contact_phone }}</span>
            </a>
          {%- endif -%}
          {%- if settings.contact_email != blank -%}
            <a href="mailto:{{ settings.contact_email }}" class="footer__contact-link">
              {%- render 'icon-mail' -%}
              <span>{{ settings.contact_email }}</span>
            </a>
          {%- endif -%}
        </div>
        
        {%- if section.settings.tagline != blank -%}
          <p class="footer__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
      </div>
      
      {%- comment -%} Navigation Columns {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <div class="footer__nav" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__nav-title">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer__nav-list">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li>
                      <a href="{{ link.url }}" class="footer__nav-link">
                        {%- render 'icon-arrow' -%}
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
            
          {%- when 'cta_box' -%}
            <div class="footer__cta" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__cta-title">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="footer__cta-text">{{ block.settings.text }}</p>
              {%- endif -%}
              {%- if block.settings.button_text != blank and block.settings.button_url != blank -%}
                <a href="{{ block.settings.button_url }}" class="btn btn--white btn--sm">
                  {%- render 'icon-arrow' -%}
                  {{ block.settings.button_text }}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
    
    {%- if show_payment_icons -%}
      <div class="footer__payment">
        <p class="footer__payment-title">{{ 'sections.footer.payment_methods' | t }}</p>
        <div class="footer__payment-icons">
          {%- for type in shop.enabled_payment_types -%}
            <span class="footer__payment-icon">
              {{ type | payment_type_svg_tag }}
            </span>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
    
    <div class="footer__bottom">
      <p class="footer__copyright">
        {{ 'sections.footer.copyright' | t: year: 'now' | date: '%Y', shop_name: shop.name }}
      </p>
      
      <div class="footer__legal">
        {%- for block in section.blocks -%}
          {%- if block.type == 'legal_link' -%}
            <a href="{{ block.settings.link }}" class="footer__legal-link" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      
      {%- if settings.social_facebook != blank or settings.social_instagram != blank or settings.social_linkedin != blank -%}
        <div class="footer__social">
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" class="footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" class="footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_linkedin != blank -%}
            <a href="{{ settings.social_linkedin }}" class="footer__social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline / Beschreibung",
      "default": "Ihr zuverlässiger Partner für hochwertige PV-Komponenten."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Zahlungsarten anzeigen",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menü",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Kategorien"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menü"
        }
      ]
    },
    {
      "type": "cta_box",
      "name": "CTA Box",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Sie haben Fragen?"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Unser Team hilft Ihnen gerne weiter!"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button-Text",
          "default": "Jetzt kontaktieren"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button-Link"
        }
      ]
    },
    {
      "type": "legal_link",
      "name": "Rechtlicher Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Text",
          "default": "Datenschutz"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "menu",
        "settings": {
          "heading": "Kategorien"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Navigation"
        }
      },
      {
        "type": "cta_box"
      },
      {
        "type": "legal_link",
        "settings": {
          "label": "Datenschutz"
        }
      },
      {
        "type": "legal_link",
        "settings": {
          "label": "Impressum"
        }
      },
      {
        "type": "legal_link",
        "settings": {
          "label": "AGB"
        }
      }
    ]
  }
}
{% endschema %}

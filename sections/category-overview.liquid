{%- comment -%}
  Category Overview Section
  Grid of category tiles linking to collections
{%- endcomment -%}

<section class="category-overview section" id="categories-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="section-header text-center">
        {%- if section.settings.subheading != blank -%}
          <p class="section-subtitle text-sm text-muted uppercase">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="section-title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}
    
    <div class="category-overview__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'category' -%}
            <a href="{{ block.settings.link }}" class="category-card" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <div class="category-card__image">
                  <img
                    src="{{ block.settings.image | image_url: width: 400 }}"
                    srcset="
                      {{ block.settings.image | image_url: width: 200 }} 200w,
                      {{ block.settings.image | image_url: width: 400 }} 400w
                    "
                    sizes="(min-width: 990px) 20vw, (min-width: 750px) 33vw, 50vw"
                    alt="{{ block.settings.title | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                </div>
              {%- elsif block.settings.icon != blank -%}
                <div class="category-card__icon">
                  {{ block.settings.icon }}
                </div>
              {%- else -%}
                <div class="category-card__image category-card__image--placeholder">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {%- endif -%}
              
              <div class="category-card__content">
                {%- if block.settings.title != blank -%}
                  <h3 class="category-card__title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="category-card__description">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .category-overview__grid {
    display: grid;
    gap: var(--spacing-md);
    grid-template-columns: repeat(2, 1fr);
  }
  
  @media (min-width: 750px) {
    .category-overview__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-lg);
    }
  }
  
  @media (min-width: 990px) {
    .category-overview__grid {
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    }
  }
  
  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--spacing-lg);
    background-color: #f9fafb;
    border-radius: var(--radius-md);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  
  .category-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  
  .category-card__image {
    width: 80px;
    height: 80px;
    margin-bottom: var(--spacing-md);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  
  .category-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .category-card__icon {
    width: 60px;
    height: 60px;
    margin-bottom: var(--spacing-md);
    color: var(--color-primary);
  }
  
  .category-card__icon svg {
    width: 100%;
    height: 100%;
  }
  
  .category-card__title {
    font-size: var(--font-size-md);
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }
  
  .category-card__description {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }
</style>

{% schema %}
{
  "name": "Kategorie-Übersicht",
  "tag": "section",
  "class": "section-category-overview",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Untertitel",
      "default": "Alle Kategorien"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Qualität, auf die Sie bauen können"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Spalten (Desktop)",
      "min": 3,
      "max": 6,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategorie",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Kategorie"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Beschreibung (optional)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        },
        {
          "type": "html",
          "id": "icon",
          "label": "Icon (SVG, optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kategorie-Übersicht",
      "blocks": [
        { "type": "category", "settings": { "title": "Unterkonstruktion" } },
        { "type": "category", "settings": { "title": "Solarmodule" } },
        { "type": "category", "settings": { "title": "Wechselrichter" } },
        { "type": "category", "settings": { "title": "Batteriespeicher" } },
        { "type": "category", "settings": { "title": "Zubehör" } }
      ]
    }
  ]
}
{% endschema %}

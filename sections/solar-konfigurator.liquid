{% comment %}
  Solar-Konfigurator – Theme Section
  ────────────────────────────────────────────────────────────────────────────
  Einbinden:
    1. Als "sections/solar-konfigurator.liquid" ins Theme (Themes → Code bearbeiten → sections)
    2. Section im Theme Editor auf die Seite legen (z. B. „Solar-Konfigurator“-Seite)

  Warenkorb (Cart-Permalink):
    Bei iframe: Vercel sendet postMessage(solar:cartRedirect) an diese Seite; das Script unten
    führt window.location zur Cart-URL aus (nicht im iframe – Shopify blockt frame-ancestors).
    Auf Vercel: window.SOLAR_SHOP_ORIGIN in index.html. Siehe docs/THEME_BRIDGE.md
  ────────────────────────────────────────────────────────────────────────────
{% endcomment %}

<section
  id="solar-konfigurator-section"
  class="solar-konfigurator-section page-width"
  style="padding: {{ section.settings.vertical_padding }}px 0;"
>
  {% if section.settings.show_heading %}
    <div class="solar-konfigurator-header" style="text-align: {{ section.settings.heading_align }}; margin-bottom: 1.5rem;">
      <h2 class="solar-konfigurator-title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="solar-konfigurator-sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if section.settings.display_mode == 'iframe' %}
    {%- comment -%}
      Start-Höhe aus Theme; Konfigurator meldet per postMessage (solar:iframeHeight) die benötigte Höhe –
      Shop passt iframe an → kein Scrollen innerhalb des iframe nötig (bis max. ca. 95% Fensterhöhe).
    {%- endcomment -%}
    <div
      class="solar-konfigurator-iframe-wrapper"
      style="position: relative; width: 100%; min-height: {{ section.settings.iframe_height }}px; border: none;"
    >
      <iframe
        class="solar-konfigurator-iframe"
        src="{{ section.settings.konfigurator_url }}"
        title="Solar-Konfigurator"
        style="width: 100%; height: {{ section.settings.iframe_height }}px; border: 0; border-radius: {{ section.settings.border_radius }}px; display: block;"
        loading="lazy"
        allow="clipboard-write"
        referrerpolicy="origin"
      ></iframe>
    </div>

  {% else %}
    {%- comment -%} Button/Link: Konfigurator auf Vercel; Warenkorb per Permalink wie im iframe. ── {%- endcomment -%}
    <div class="solar-konfigurator-cta" style="text-align: {{ section.settings.heading_align }};">
      <a
        href="{{ section.settings.konfigurator_url }}"
        class="button button--primary solar-konfigurator-btn"
        {% if section.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
        style="
          display: inline-block;
          padding: 14px 32px;
          font-size: 1.1rem;
          font-weight: 600;
          text-decoration: none;
          border-radius: {{ section.settings.border_radius }}px;
          background-color: {{ section.settings.button_color }};
          color: {{ section.settings.button_text_color }};
        "
      >
        {{ section.settings.button_label }}
      </a>
      {% if section.settings.button_note != blank %}
        <p style="margin-top: 0.75rem; font-size: 0.9rem; opacity: 0.7;">{{ section.settings.button_note }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if section.settings.konfigurator_url != blank %}
    <script>
      (function () {
        var cfgUrl = {{ section.settings.konfigurator_url | json }};
        var sectionEl = document.getElementById('solar-konfigurator-section');
        function allowedOrigin() {
          try {
            return new URL(cfgUrl).origin;
          } catch (e) {
            return '';
          }
        }
        window.addEventListener('message', function (event) {
          var ao = allowedOrigin();
          if (!ao || event.origin !== ao) return;
          var d = event.data;
          if (!d || typeof d !== 'object') return;

          if (d.type === 'solar:cartRedirect' && typeof d.url === 'string') {
            window.location.href = d.url;
            return;
          }

          if (d.type === 'solar:iframeHeight' && typeof d.height === 'number' && sectionEl) {
            var iframe = sectionEl.querySelector('iframe.solar-konfigurator-iframe');
            if (!iframe) return;
            var maxPx = Math.round(window.innerHeight * 0.95);
            var h = Math.min(Math.max(Math.round(d.height), 400), maxPx, 5600);
            iframe.style.height = h + 'px';
            var wrap = sectionEl.querySelector('.solar-konfigurator-iframe-wrapper');
            if (wrap) wrap.style.minHeight = h + 'px';
          }
        });
      })();
    </script>
  {% endif %}
</section>

<style>
  .solar-konfigurator-section { width: 100%; }
  .solar-konfigurator-title { font-size: 1.8rem; font-weight: 700; margin: 0 0 0.5rem; }
  .solar-konfigurator-sub { font-size: 1.05rem; opacity: 0.8; margin: 0; }
  @media (max-width: 749px) {
    .solar-konfigurator-title { font-size: 1.4rem; }
    /* iframe-Höhe kommt von postMessage (solar:iframeHeight) – kein !important gegen inline style */
    .solar-konfigurator-iframe-wrapper { min-height: 70vh; }
  }
</style>

{% schema %}
{
  "name": "Solar-Konfigurator",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Konfigurator-URL"
    },
    {
      "type": "url",
      "id": "konfigurator_url",
      "label": "URL des Solar-Konfigurators (Vercel)",
      "info": "z. B. https://solar-tool-shopify.vercel.app — ohne abschließenden Slash"
    },
    {
      "type": "header",
      "content": "Einbindung & Shopify-Warenkorb"
    },
    {
      "type": "paragraph",
      "content": "iframe: postMessage vom Konfigurator – diese Section enthält den Listener (Theme-Datei aktuell halten). Vercel index.html: SOLAR_SHOP_ORIGIN = Shop-URL. Konfigurator-URL muss exakt der iframe-src entsprechen (Origin-Check). docs/THEME_BRIDGE.md"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Anzeige-Modus",
      "options": [
        {
          "value": "button",
          "label": "Button / Link (Konfigurator auf Vercel)"
        },
        {
          "value": "iframe",
          "label": "iframe (eingebettet – Warenkorb per Permalink)"
        }
      ],
      "default": "button",
      "info": "So prüfen: Theme Editor → diese Section → Feld „Anzeige-Modus“. iframe = eingebettetes Vercel-Fenster."
    },
    {
      "type": "header",
      "content": "Überschrift"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Überschrift anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Solaranlage konfigurieren"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile (optional)",
      "default": "Stellen Sie Ihre Solaranlage zusammen – Komponenten werden direkt in den Warenkorb gelegt."
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Ausrichtung",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Button-Einstellungen (Modus: Button)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Zum Solar-Konfigurator →"
    },
    {
      "type": "text",
      "id": "button_note",
      "label": "Hinweis unter Button (optional)",
      "default": "Kostenlos & ohne Anmeldung"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "In neuem Tab öffnen",
      "default": false
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button-Farbe",
      "default": "#1a6b3c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button-Textfarbe",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "iframe-Einstellungen (nur wenn Modus „iframe“)"
    },
    {
      "type": "range",
      "id": "iframe_height",
      "label": "iframe Start-Höhe (px)",
      "info": "Wird nach Laden durch den Konfigurator per Nachricht angepasst. Nur Fallback / erster Paint.",
      "min": 400,
      "max": 2000,
      "step": 50,
      "default": 1100
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertikaler Abstand (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Eckenradius (px)",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Solar-Konfigurator"
    }
  ]
}
{% endschema %}

{% comment %}
  Solar-Konfigurator – Theme Section
  ────────────────────────────────────────────────────────────────────────────
  Einbinden:
    1. Diese Datei als "sections/solar-konfigurator.liquid" ins Theme hochladen
       (Online Shop → Themes → Code bearbeiten → sections → Neue Datei)
    2. Im Theme Editor den Block "Solar-Konfigurator" auf die gewünschte Seite ziehen
       ODER in einer Page den Shortcode per Liquid einbinden.
  ────────────────────────────────────────────────────────────────────────────
{% endcomment %}

<section
  id="solar-konfigurator-section"
  class="solar-konfigurator-section page-width"
  style="padding: {{ section.settings.vertical_padding }}px 0;"
>
  {% if section.settings.show_heading %}
    <div class="solar-konfigurator-header" style="text-align: {{ section.settings.heading_align }}; margin-bottom: 1.5rem;">
      <h2 class="solar-konfigurator-title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="solar-konfigurator-sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

    {%- comment -%} ── VARIANTE A: iframe (empfohlen, volle Integration) ── {%- endcomment -%}
    <div class="solar-konfigurator-iframe-wrapper" style="position: relative; width: 100%; min-height: {{ section.settings.iframe_height }}px; border: none;">
      <iframe
        src="{{ section.settings.konfigurator_url }}"
        title="Solar-Konfigurator"
        style="width: 100%; height: {{ section.settings.iframe_height }}px; border: 0; border-radius: {{ section.settings.border_radius }}px;"
        loading="lazy"
        allow="clipboard-write"
        referrerpolicy="origin"
      ></iframe>
    </div>
</section>

<style>
  .solar-konfigurator-section { width: 100%; }
  .solar-konfigurator-title { font-size: 1.8rem; font-weight: 700; margin: 0 0 0.5rem; }
  .solar-konfigurator-sub { font-size: 1.05rem; opacity: 0.8; margin: 0; }
  @media (max-width: 749px) {
    .solar-konfigurator-title { font-size: 1.4rem; }
    .solar-konfigurator-iframe-wrapper iframe { height: 90vh !important; }
  }
</style>

{% schema %}
{
  "name": "Solar-Konfigurator",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Konfigurator URL"
    },
    {
      "type": "url",
      "id": "konfigurator_url",
      "label": "URL des Solar-Konfigurators",
      "info": "https://solar-tool-shopify.vercel.app/"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Anzeige-Modus",
      "options": [
        { "value": "iframe", "label": "iframe (direkt eingebettet)" },
        { "value": "button", "label": "Button / Link (öffnet Konfigurator)" }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "Überschrift"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Überschrift anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Solaranlage konfigurieren"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile (optional)",
      "default": "Stellen Sie Ihre Solaranlage zusammen – Komponenten werden direkt in den Warenkorb gelegt."
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Ausrichtung",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Button-Einstellungen (Modus: Button)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Zum Solar-Konfigurator →"
    },
    {
      "type": "text",
      "id": "button_note",
      "label": "Hinweis unter Button (optional)",
      "default": "Kostenlos & ohne Anmeldung"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "In neuem Tab öffnen",
      "default": false
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button-Farbe",
      "default": "#1a6b3c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button-Textfarbe",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "iframe-Einstellungen (Modus: iframe)"
    },
    {
      "type": "range",
      "id": "iframe_height",
      "label": "iframe Höhe (px)",
      "min": 400,
      "max": 1200,
      "step": 50,
      "default": 850
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertikaler Abstand (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Eckenradius (px)",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Solar-Konfigurator"
    }
  ]
}
{% endschema %}
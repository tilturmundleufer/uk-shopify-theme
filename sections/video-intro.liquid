{%- comment -%}
  Video-/Intro-Bereich: YouTube (URL) oder hochgeladenes Video
{%- endcomment -%}

{%- liquid
  assign raw = section.settings.youtube_url | default: ''
  assign vid = ''
  if raw contains 'youtu.be/'
    assign vid = raw | split: 'youtu.be/' | last | split: '?' | first | split: '/' | first
  elsif raw contains 'v='
    assign vid = raw | split: 'v=' | last | split: '&' | first
  elsif raw != blank
    assign vid = raw | strip
  endif
-%}

<section class="video-intro section" id="video-intro-{{ section.id }}">
  <div class="page-width video-intro__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="video-intro__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="video-intro__text rte">{{ section.settings.text }}</div>
    {%- endif -%}

    <div class="video-intro__media">
      {%- if section.settings.custom_embed_liquid != blank -%}
        <div class="video-intro__custom">
          {{ section.settings.custom_embed_liquid }}
        </div>
      {%- elsif section.settings.video_file != blank -%}
        {{ section.settings.video_file | video_tag: image_size: '1400x', controls: true, class: 'video-intro__video', playsinline: true }}
      {%- elsif vid != blank -%}
        <div class="video-intro__embed">
          <iframe
            src="https://www.youtube-nocookie.com/embed/{{ vid }}?rel=0"
            title="{{ section.settings.heading | default: 'Video' | escape }}"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      {%- elsif section.settings.poster != blank -%}
        <div class="video-intro__poster">
          <img
            src="{{ section.settings.poster | image_url: width: 1600 }}"
            alt="{{ section.settings.poster_alt | default: section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.poster.width }}"
            height="{{ section.settings.poster.height }}"
          >
          <p class="video-intro__placeholder-hint">{{ section.settings.placeholder_hint }}</p>
        </div>
      {%- else -%}
        <div class="video-intro__placeholder">
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          <p class="video-intro__placeholder-hint">{{ section.settings.placeholder_hint }}</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .video-intro {
    padding: var(--spacing-2xl) 0;
  }
  .video-intro__heading {
    text-align: center;
    margin-bottom: var(--spacing-md);
    max-width: 52ch;
    margin-left: auto;
    margin-right: auto;
  }
  .video-intro__text {
    text-align: center;
    max-width: 65ch;
    margin: 0 auto var(--spacing-xl);
    color: var(--color-ink-soft);
  }
  .video-intro__embed {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: #0f172a;
  }
  .video-intro__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .video-intro__video {
    width: 100%;
    border-radius: var(--radius-md);
    background: #000;
    display: block;
  }
  .video-intro__custom {
    width: 100%;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: #0f172a;
  }
  .video-intro__custom :is(video, iframe) {
    display: block;
    width: 100%;
    min-height: 360px;
    border: 0;
  }
  .video-intro__poster img {
    width: 100%;
    border-radius: var(--radius-md);
    object-fit: cover;
    max-height: 560px;
  }
  .video-intro__poster {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }
  .video-intro__placeholder {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: #f3f4f6;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  .video-intro__placeholder .placeholder-svg {
    width: 120px;
    height: auto;
    opacity: 0.35;
  }
  .video-intro__placeholder-hint {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    text-align: center;
    padding: 0 var(--spacing-md);
    max-width: 42ch;
  }
</style>

{% schema %}
{
  "name": "Video / Intro",
  "tag": "section",
  "class": "section-video-intro",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift (optional)"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Einleitungstext (optional)"
    },
    {
      "type": "liquid",
      "id": "custom_embed_liquid",
      "label": "Custom Liquid (Player / Embed)",
      "info": "z. B. Script von jsDelivr oder eigener Player. Hat Vorrang vor allen anderen Video-Optionen."
    },
    {
      "type": "video",
      "id": "video_file",
      "label": "Video aus Medien (optional)",
      "info": "Hat Vorrang vor YouTube."
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "YouTube-URL oder Video-ID",
      "info": "z. B. https://www.youtube.com/watch?v=… oder nur die ID"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Vorschaubild (wenn kein Video gesetzt)"
    },
    {
      "type": "text",
      "id": "poster_alt",
      "label": "Alt-Text Poster"
    },
    {
      "type": "text",
      "id": "placeholder_hint",
      "label": "Hinweis im Platzhalter",
      "default": "YouTube-Link oder Video unter „Video aus Medien“ im Theme-Editor hinterlegen."
    }
  ],
  "presets": [{ "name": "Video / Intro" }]
}
{% endschema %}

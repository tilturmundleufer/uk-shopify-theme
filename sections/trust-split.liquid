{%- comment -%}
  Vertrauen: Bild links, Text + Zertifikate rechts (Bild + Legende je Zertifikat)
{%- endcomment -%}

<section class="trust-split section" id="trust-{{ section.id }}">
  <div class="page-width trust-split__grid">
    <div class="trust-split__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1100 }}"
          srcset="
            {{ section.settings.image | image_url: width: 550 }} 550w,
            {{ section.settings.image | image_url: width: 1100 }} 1100w
          "
          sizes="(min-width: 990px) 46vw, 100vw"
          alt="{{ section.settings.image_alt | default: section.settings.heading | escape }}"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          class="trust-split__img"
        >
      {%- else -%}
        <div class="trust-split__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="trust-split__content">
      {%- if section.settings.kicker != blank -%}
        <p class="trust-split__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="trust-split__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="trust-split__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="trust-split__certs" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'badge' -%}
              <li class="trust-split__cert" {{ block.shopify_attributes }}>
                <div class="trust-split__cert-visual">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 560 }}"
                      srcset="
                        {{ block.settings.image | image_url: width: 280 }} 280w,
                        {{ block.settings.image | image_url: width: 560 }} 560w
                      "
                      sizes="(min-width: 990px) 22vw, 45vw"
                      alt="{{ block.settings.title | default: 'Zertifikat' | escape }}"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      class="trust-split__cert-img"
                    >
                  {%- else -%}
                    <span class="trust-split__badge-fallback">{{ block.settings.title | default: 'Badge' }}</span>
                  {%- endif -%}
                </div>
                <div class="trust-split__cert-copy">
                  {%- if block.settings.caption_title != blank -%}
                    <p class="trust-split__cert-title">{{ block.settings.caption_title }}</p>
                  {%- endif -%}
                  {%- if block.settings.caption != blank -%}
                    <p class="trust-split__cert-caption">{{ block.settings.caption }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .trust-split {
    padding: var(--spacing-2xl) 0;
  }
  .trust-split__grid {
    display: grid;
    gap: var(--spacing-xl);
    align-items: start;
  }
  @media (min-width: 990px) {
    .trust-split__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--spacing-3xl);
      align-items: stretch;
    }
  }
  .trust-split__img {
    width: 100%;
    border-radius: var(--radius-md);
    object-fit: cover;
    min-height: 360px;
    max-height: none;
  }
  .trust-split__placeholder {
    border-radius: var(--radius-md);
    background: #f3f4f6;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .trust-split__placeholder .placeholder-svg {
    width: 100px;
    opacity: 0.4;
  }
  .trust-split__kicker {
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    margin-bottom: var(--spacing-xs);
  }
  .trust-split__heading {
    margin-bottom: var(--spacing-md);
  }
  .trust-split__content {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .trust-split__text {
    color: var(--color-ink-soft);
    line-height: 1.65;
    margin-bottom: var(--spacing-xl);
  }
  .trust-split__certs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-lg);
    width: 100%;
    margin: 0;
    padding: 0;
    align-items: stretch;
  }
  @media (max-width: 749px) {
    .trust-split__certs {
      grid-template-columns: 1fr;
    }
  }
  @media (min-width: 990px) {
    .trust-split__content {
      min-height: 100%;
    }
    .trust-split__text {
      margin-bottom: var(--spacing-lg);
    }
    .trust-split__certs {
      margin-top: auto;
      padding-top: var(--spacing-sm);
    }
  }
  .trust-split__cert {
    list-style: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    min-width: 0;
    height: 100%;
    min-height: 100%;
  }
  .trust-split__cert-visual {
    flex: 1 1 auto;
    width: 100%;
    border-radius: var(--radius-md);
    background: #f3f4f6;
    padding: var(--spacing-md);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
  }
  .trust-split__cert-copy {
    flex-shrink: 0;
    margin-top: var(--spacing-sm);
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    align-items: flex-start;
  }
  .trust-split__cert-title {
    font-size: clamp(1rem, 2vw, 1.125rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-secondary);
    margin: 0;
    text-align: left;
  }
  .trust-split__cert-img {
    width: 100%;
    height: auto;
    max-height: 140px;
    object-fit: contain;
    object-position: center;
  }
  .trust-split__cert-caption {
    font-size: var(--font-size-xs);
    color: var(--color-ink-soft);
    line-height: 1.55;
    margin: 0;
    text-align: left;
  }
  .trust-split__badge-fallback {
    font-size: var(--font-size-xs);
    padding: 8px 12px;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-light);
  }
</style>

{% schema %}
{
  "name": "Vertrauen (Split)",
  "tag": "section",
  "class": "section-trust-split",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild (links)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alt-Text Bild"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Von Profis. Für Sie"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Höchste Produktqualität für Ihr nächstes Projekt."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Fließtext"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Zertifikat / Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild (z. B. TÜV)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Bezeichnung (Alt-Text)"
        },
        {
          "type": "text",
          "id": "caption_title",
          "label": "Überschrift unter dem Bild",
          "info": "Größer gesetzt, linksbündig."
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Zusatztext",
          "info": "Kleiner als die Überschrift, linksbündig."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vertrauen (Split)",
      "blocks": [{ "type": "badge" }, { "type": "badge" }]
    }
  ]
}
{% endschema %}

{%- comment -%}
  Vertrauen: Bild links, Text rechts, optionale Zertifikats-/Partner-Badges
{%- endcomment -%}

<section class="trust-split section" id="trust-{{ section.id }}">
  <div class="page-width trust-split__grid">
    <div class="trust-split__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          srcset="
            {{ section.settings.image | image_url: width: 450 }} 450w,
            {{ section.settings.image | image_url: width: 900 }} 900w
          "
          sizes="(min-width: 990px) 44vw, 100vw"
          alt="{{ section.settings.image_alt | default: section.settings.heading | escape }}"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          class="trust-split__img"
        >
      {%- else -%}
        <div class="trust-split__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="trust-split__content">
      {%- if section.settings.kicker != blank -%}
        <p class="trust-split__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="trust-split__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="trust-split__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="trust-split__badges" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'badge' -%}
              <li class="trust-split__badge" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 220 }}"
                    alt="{{ block.settings.title | default: 'Zertifikat' | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                {%- else -%}
                  <span class="trust-split__badge-fallback">{{ block.settings.title | default: 'Badge' }}</span>
                {%- endif -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .trust-split {
    padding: var(--spacing-2xl) 0;
  }
  .trust-split__grid {
    display: grid;
    gap: var(--spacing-xl);
    align-items: center;
  }
  @media (min-width: 990px) {
    .trust-split__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
      gap: var(--spacing-3xl);
    }
  }
  .trust-split__img {
    width: 100%;
    border-radius: var(--radius-md);
    object-fit: cover;
    max-height: 520px;
  }
  .trust-split__placeholder {
    border-radius: var(--radius-md);
    background: #f3f4f6;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .trust-split__placeholder .placeholder-svg {
    width: 100px;
    opacity: 0.4;
  }
  .trust-split__kicker {
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    margin-bottom: var(--spacing-xs);
  }
  .trust-split__heading {
    margin-bottom: var(--spacing-md);
  }
  .trust-split__text {
    color: var(--color-ink-soft);
    line-height: 1.65;
    margin-bottom: var(--spacing-lg);
  }
  .trust-split__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    align-items: center;
  }
  .trust-split__badge img {
    max-height: 52px;
    width: auto;
    object-fit: contain;
  }
  .trust-split__badge-fallback {
    font-size: var(--font-size-xs);
    padding: 8px 12px;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-light);
  }
</style>

{% schema %}
{
  "name": "Vertrauen (Split)",
  "tag": "section",
  "class": "section-trust-split",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild (links)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alt-Text Bild"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Von Profis. Für Sie"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Höchste Produktqualität für Ihr nächstes Projekt."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Fließtext"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Zertifikat / Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild (z. B. TÜV)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Bezeichnung (Alt-Text)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vertrauen (Split)",
      "blocks": [{ "type": "badge" }, { "type": "badge" }]
    }
  ]
}
{% endschema %}

{%- comment -%}
  Main Cart Section
{%- endcomment -%}

<section class="cart-page section" data-section-id="{{ section.id }}">
  <div class="page-width">
    <h1 class="cart-page__title">{{ 'cart.general.title' | t }}</h1>
    
    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" class="cart-form" data-cart-form>
        <div class="cart-page__inner">
          <div class="cart-items">
            <div class="cart-items__header">
              <span class="cart-items__header-product">Produkt</span>
              <span class="cart-items__header-price">Preis</span>
              <span class="cart-items__header-qty">Menge</span>
              <span class="cart-items__header-total">Gesamt</span>
            </div>
            
            {%- for item in cart.items -%}
              <div class="cart-item" data-cart-item data-key="{{ item.key }}">
                <div class="cart-item__image">
                  {%- if item.image -%}
                    <a href="{{ item.url }}">
                      <img
                        src="{{ item.image | image_url: width: 150 }}"
                        alt="{{ item.title | escape }}"
                        width="75"
                        height="75"
                        loading="lazy"
                      >
                    </a>
                  {%- endif -%}
                </div>
                
                <div class="cart-item__details">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  
                  <button 
                    type="button" 
                    class="cart-item__remove"
                    data-cart-remove="{{ item.key }}"
                    aria-label="{{ 'cart.general.remove' | t }}"
                  >
                    {{ 'cart.general.remove' | t }}
                  </button>
                </div>
                
                <div class="cart-item__price">
                  {%- if item.original_price != item.final_price -%}
                    <span class="cart-item__price-compare">{{ item.original_price | money }}</span>
                  {%- endif -%}
                  <span class="cart-item__price-current{% if item.original_price != item.final_price %} text-sale{% endif %}">
                    {{ item.final_price | money }}
                  </span>
                </div>
                
                <div class="cart-item__qty">
                  {%- render 'qty-stepper', 
                    variant: item.variant, 
                    value: item.quantity,
                    name: 'updates[]',
                    size: 'sm'
                  -%}
                </div>
                
                <div class="cart-item__total">
                  {{ item.final_line_price | money }}
                </div>
              </div>
            {%- endfor -%}
          </div>
          
          <div class="cart-summary">
            <div class="cart-summary__inner">
              {%- if settings.show_cart_note -%}
                <div class="cart-summary__note">
                  <label for="CartNote" class="cart-summary__note-label">{{ 'cart.general.note' | t }}</label>
                  <textarea 
                    id="CartNote" 
                    name="note" 
                    class="cart-summary__note-input"
                    placeholder="{{ 'cart.general.note' | t }}"
                  >{{ cart.note }}</textarea>
                </div>
              {%- endif -%}
              
              <div class="cart-summary__totals">
                <div class="cart-summary__row">
                  <span>{{ 'cart.general.subtotal' | t }}</span>
                  <span class="cart-summary__subtotal">{{ cart.total_price | money }}</span>
                </div>
                <p class="cart-summary__info">{{ 'cart.general.taxes_and_shipping' | t }}</p>
              </div>
              
              <div class="cart-summary__actions">
                <button type="submit" name="update" class="btn btn--secondary btn--full">
                  {{ 'cart.general.update' | t }}
                </button>
                <button type="submit" name="checkout" class="btn btn--primary btn--full btn--lg">
                  {{ 'cart.general.checkout' | t }}
                </button>
              </div>
            </div>
          </div>
        </div>
      </form>
    {%- else -%}
      <div class="cart-empty">
        <p>{{ 'cart.general.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
          {{ 'cart.general.continue_shopping' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .cart-page__title {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--spacing-xl);
  }
  
  .cart-page__inner {
    display: grid;
    gap: var(--spacing-xl);
  }
  
  @media (min-width: 990px) {
    .cart-page__inner {
      grid-template-columns: 1fr 380px;
    }
  }
  
  /* Cart Items */
  .cart-items__header {
    display: none;
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-light);
  }
  
  @media (min-width: 750px) {
    .cart-items__header {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: var(--spacing-md);
    }
  }
  
  .cart-item {
    display: grid;
    grid-template-columns: 75px 1fr;
    gap: var(--spacing-md);
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--color-border);
  }
  
  @media (min-width: 750px) {
    .cart-item {
      grid-template-columns: 75px 1fr 100px 120px 100px;
      align-items: center;
    }
  }
  
  .cart-item__image img {
    width: 75px;
    height: 75px;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }
  
  .cart-item__details {
    grid-column: 2;
  }
  
  @media (min-width: 750px) {
    .cart-item__details {
      grid-column: auto;
    }
  }
  
  .cart-item__title {
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
    display: block;
  }
  
  .cart-item__variant {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    margin-bottom: var(--spacing-sm);
  }
  
  .cart-item__remove {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
    text-decoration: underline;
    cursor: pointer;
  }
  
  .cart-item__remove:hover {
    color: var(--color-error);
  }
  
  .cart-item__price,
  .cart-item__qty,
  .cart-item__total {
    display: none;
  }
  
  @media (min-width: 750px) {
    .cart-item__price,
    .cart-item__qty,
    .cart-item__total {
      display: block;
    }
  }
  
  .cart-item__price-compare {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    text-decoration: line-through;
  }
  
  .cart-item__total {
    font-weight: 600;
  }
  
  /* Cart Summary */
  .cart-summary__inner {
    position: sticky;
    top: calc(var(--header-height) + var(--spacing-lg));
    padding: var(--spacing-lg);
    background-color: #f9fafb;
    border-radius: var(--radius-md);
  }
  
  .cart-summary__note {
    margin-bottom: var(--spacing-lg);
  }
  
  .cart-summary__note-label {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }
  
  .cart-summary__note-input {
    width: 100%;
    min-height: 80px;
    padding: var(--spacing-sm);
    font-size: var(--font-size-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
  }
  
  .cart-summary__totals {
    padding: var(--spacing-lg) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
  }
  
  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }
  
  .cart-summary__info {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }
  
  .cart-summary__actions {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
  
  /* Empty Cart */
  .cart-empty {
    text-align: center;
    padding: var(--spacing-3xl);
  }
  
  .cart-empty p {
    font-size: var(--font-size-lg);
    color: var(--color-text-light);
    margin-bottom: var(--spacing-lg);
  }
</style>

{% schema %}
{
  "name": "Warenkorb",
  "tag": "section",
  "class": "section-main-cart"
}
{% endschema %}

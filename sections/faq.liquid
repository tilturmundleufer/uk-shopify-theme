{%- comment -%}
  FAQ Section with Accordion
{%- endcomment -%}

<section class="faq-section section" id="faq-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-header text-center">
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="section-subtitle mt-sm">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
    
    <div class="faq-list">
      <div class="accordion faq-accordion" data-accordion>
        {%- for block in section.blocks -%}
          <div class="accordion__item" {{ block.shopify_attributes }}>
            <button 
              class="accordion__header" 
              aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="faq-{{ block.id }}"
              data-accordion-header
            >
              {{ block.settings.question }}
              <span class="accordion__icon">{%- render 'icon-chevron' -%}</span>
            </button>
            <div 
              class="accordion__content" 
              id="faq-{{ block.id }}" 
              aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
              data-accordion-content
            >
              <div class="accordion__inner">
                <div class="accordion__body rte">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
  }
</style>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Häufig gestellte Fragen"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Untertitel"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Frage",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Frage",
          "default": "Was ist die Lieferzeit?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Antwort",
          "default": "<p>Die Lieferzeit beträgt in der Regel 1-4 Werktage.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "Was ist die Lieferzeit?" } },
        { "type": "faq", "settings": { "question": "Wie kann ich bezahlen?" } },
        { "type": "faq", "settings": { "question": "Kann ich meine Bestellung zurückgeben?" } }
      ]
    }
  ]
}
{% endschema %}

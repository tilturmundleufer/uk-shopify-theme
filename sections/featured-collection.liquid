{%- comment -%}
  Featured Collection Section with Category Tabs
  Inspired by unterkonstruktion.de design
{%- endcomment -%}

{{ 'section-featured-products.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show
  assign show_view_all = section.settings.show_view_all
  assign show_tabs = section.settings.show_tabs
-%}

<section class="featured-products section{% if section.settings.alternate_bg %} featured-products--alt{% endif %}" id="featured-{{ section.id }}">
  <div class="page-width">
    {%- comment -%} Category Tabs {%- endcomment -%}
    {%- if show_tabs and section.blocks.size > 0 -%}
      <div class="featured-products__tabs">
        <div class="category-tabs">
          {%- for block in section.blocks -%}
            {%- if block.type == 'category_tab' -%}
              {%- assign tab_collection = collections[block.settings.collection] -%}
              <a 
                href="{{ tab_collection.url | default: '#' }}" 
                class="category-tabs__tab{% if forloop.first %} category-tabs__tab--active{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.label | default: tab_collection.title | default: 'Kategorie' }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
    
    {%- comment -%} Header (optional - when no tabs) {%- endcomment -%}
    {%- unless show_tabs -%}
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="featured-products__header">
          <div class="featured-products__title-wrapper">
            {%- if section.settings.subheading != blank -%}
              <p class="featured-products__subtitle">{{ section.settings.subheading }}</p>
            {%- endif -%}
            
            {%- if section.settings.heading != blank -%}
              <h2 class="featured-products__title">{{ section.settings.heading }}</h2>
            {%- elsif collection != blank -%}
              <h2 class="featured-products__title">{{ collection.title }}</h2>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endunless -%}
    
    {%- comment -%} Product Grid {%- endcomment -%}
    <div class="featured-products__grid product-grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: products_to_show -%}
          {%- render 'product-card', 
            product: product, 
            show_qty_stepper: section.settings.show_qty_stepper,
            lazy_load: true
          -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          <div class="product-card">
            <div class="product-card__image-wrapper">
              {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="product-card__content">
              <div class="product-card__stock">
                <span class="stock-badge stock-badge--in-stock stock-badge--minimal">
                  <span class="stock-badge__dot"></span>
                  <span class="stock-badge__text">Auf Lager</span>
                </span>
              </div>
              <div class="product-card__price-wrapper">
                <span class="product-card__price product-card__price--compare">29,99 €</span>
                <div class="product-card__price-row">
                  <span class="product-card__price">19,99 €</span>
                  <span class="product-card__price-unit">(19,99 €/ Stück)</span>
                </div>
              </div>
              <h3 class="product-card__title">Beispielprodukt {{ forloop.index }}</h3>
              <p class="product-card__description">Produktbeschreibung hier einfügen...</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
    
    {%- comment -%} View All Button {%- endcomment -%}
    {%- if show_view_all and collection != blank -%}
      <div class="featured-products__footer">
        <a href="{{ collection.url }}" class="btn btn--secondary btn--arrow">
          {{ 'sections.featured_collection.view_all' | t }}
          {%- render 'icon-arrow' -%}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "header",
      "content": "Kategorie-Tabs"
    },
    {
      "type": "checkbox",
      "id": "show_tabs",
      "label": "Kategorie-Tabs anzeigen",
      "default": true,
      "info": "Zeigt Tabs über den Produkten. Tabs werden über Blöcke definiert."
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Untertitel (optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "info": "Wird nur angezeigt, wenn Tabs deaktiviert sind"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Anzahl Produkte",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_qty_stepper",
      "label": "Mengen-Stepper anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "\"Alle ansehen\" Button anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "alternate_bg",
      "label": "Alternativer Hintergrund",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "category_tab",
      "name": "Kategorie-Tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tab-Label",
          "info": "Leer lassen für Collection-Titel"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "blocks": [
        { "type": "category_tab", "settings": { "label": "Unterkonstruktion" } },
        { "type": "category_tab", "settings": { "label": "Solarmodule" } },
        { "type": "category_tab", "settings": { "label": "Wechselrichter" } },
        { "type": "category_tab", "settings": { "label": "Batteriespeicher" } },
        { "type": "category_tab", "settings": { "label": "Zubehör" } }
      ]
    }
  ]
}
{% endschema %}

{%- comment -%}
  Featured Collection mit Kategorie-Tabs (ohne Seitenwechsel)
{%- endcomment -%}

{{ 'section-featured-products.css' | asset_url | stylesheet_tag }}
<script src="{{ 'featured-collection-tabs.js' | asset_url }}" defer></script>

{%- liquid
  assign products_to_show = section.settings.products_to_show
  assign show_view_all = section.settings.show_view_all
  assign show_tabs = section.settings.show_tabs
  assign collection = collections[section.settings.collection]
  assign tab_blocks_count = 0
  for block in section.blocks
    if block.type == 'category_tab'
      assign tab_blocks_count = tab_blocks_count | plus: 1
    endif
  endfor
  assign use_tab_panels = false
  if show_tabs and tab_blocks_count > 0
    assign use_tab_panels = true
  endif
-%}

<section
  class="featured-products section{% if section.settings.alternate_bg %} featured-products--alt{% endif %}"
  id="featured-{{ section.id }}"
  data-featured-collection-root
>
  <div class="page-width">
    {%- comment -%} Abschnitts-Überschrift (wie Referenz: Titel über den Tabs) {%- endcomment -%}
    {%- if section.settings.show_section_heading -%}
      <div class="featured-products__header featured-products__header--with-tabs">
        <div class="featured-products__title-wrapper">
          {%- if section.settings.subheading != blank -%}
            <p class="featured-products__subtitle">{{ section.settings.subheading }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="featured-products__title">{{ section.settings.heading }}</h2>
          {%- elsif collection != blank -%}
            <h2 class="featured-products__title">{{ collection.title }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.header_link_label != blank and section.settings.header_link_url != blank -%}
          <a href="{{ section.settings.header_link_url }}" class="featured-products__link">
            {{ section.settings.header_link_label }}
            {%- render 'icon-arrow' -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if use_tab_panels -%}
      <div class="featured-products__tabs" data-featured-tabs>
        <div class="category-tabs" role="tablist" aria-label="{{ section.settings.heading | default: 'Kategorien' | escape }}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'category_tab' -%}
              {%- assign tab_collection = collections[block.settings.collection] -%}
              {%- assign tab_label = block.settings.label | default: tab_collection.title | default: 'Kategorie' -%}
              {%- assign panel_id = 'fc-panel-' | append: section.id | append: '-' | append: block.id -%}
              <button
                type="button"
                class="category-tabs__tab{% if forloop.first %} category-tabs__tab--active{% endif %}"
                role="tab"
                id="tab-{{ block.id }}"
                aria-controls="{{ panel_id }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-tab-button
                data-tab-target="{{ panel_id }}"
                {{ block.shopify_attributes }}
              >
                {{ tab_label }}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'category_tab' -%}
          {%- assign tab_collection = collections[block.settings.collection] -%}
          {%- assign panel_id = 'fc-panel-' | append: section.id | append: '-' | append: block.id -%}
          <div
            id="{{ panel_id }}"
            class="featured-products__panel"
            role="tabpanel"
            aria-labelledby="tab-{{ block.id }}"
            data-tab-panel
            {% unless forloop.first %}hidden{% endunless %}
          >
            <div class="featured-products__grid product-grid">
              {%- if tab_collection != blank -%}
                {%- for product in tab_collection.products limit: products_to_show -%}
                  {%- render 'product-card',
                    product: product,
                    show_qty_stepper: section.settings.show_qty_stepper,
                    lazy_load: true
                  -%}
                {%- endfor -%}
              {%- else -%}
                {%- for i in (1..products_to_show) -%}
                  <div class="product-card">
                    <div class="product-card__image-wrapper">
                      {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                    <div class="product-card__content">
                      <div class="product-card__stock">
                        <span class="stock-badge stock-badge--in-stock stock-badge--minimal">
                          <span class="stock-badge__dot"></span>
                          <span class="stock-badge__text">{{ 'products.product.in_stock' | t }}</span>
                        </span>
                      </div>
                      <h3 class="product-card__title">Beispielprodukt</h3>
                    </div>
                  </div>
                {%- endfor -%}
              {%- endif -%}
            </div>

            {%- if show_view_all and tab_collection != blank -%}
              <div class="featured-products__footer">
                <a href="{{ tab_collection.url }}" class="btn btn--cta btn--arrow">
                  {{ 'sections.featured_collection.view_all' | t }}
                  {%- render 'icon-arrow' -%}
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

    {%- elsif show_tabs and tab_blocks_count == 0 -%}
      {%- comment -%} Fallback: nur Links zur Collection, wenn keine Tab-Blöcke {%- endcomment -%}
      <div class="featured-products__tabs">
        <div class="category-tabs">
          {%- if collection != blank -%}
            <a href="{{ collection.url }}" class="category-tabs__tab category-tabs__tab--active">
              {{ collection.title }}
            </a>
          {%- endif -%}
        </div>
      </div>
      <div class="featured-products__grid product-grid">
        {%- if collection != blank -%}
          {%- for product in collection.products limit: products_to_show -%}
            {%- render 'product-card', product: product, show_qty_stepper: section.settings.show_qty_stepper, lazy_load: true -%}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..products_to_show) -%}
            <div class="product-card">
              <div class="product-card__image-wrapper">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      {%- if show_view_all and collection != blank -%}
        <div class="featured-products__footer">
          <a href="{{ collection.url }}" class="btn btn--cta btn--arrow">
            {{ 'sections.featured_collection.view_all' | t }}
            {%- render 'icon-arrow' -%}
          </a>
        </div>
      {%- endif -%}

    {%- else -%}
      {%- comment -%} Ohne Tabs: klassische Überschrift + Grid {%- endcomment -%}
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="featured-products__header">
          <div class="featured-products__title-wrapper">
            {%- if section.settings.subheading != blank -%}
              <p class="featured-products__subtitle">{{ section.settings.subheading }}</p>
            {%- endif -%}
            {%- if section.settings.heading != blank -%}
              <h2 class="featured-products__title">{{ section.settings.heading }}</h2>
            {%- elsif collection != blank -%}
              <h2 class="featured-products__title">{{ collection.title }}</h2>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <div class="featured-products__grid product-grid">
        {%- if collection != blank -%}
          {%- for product in collection.products limit: products_to_show -%}
            {%- render 'product-card', product: product, show_qty_stepper: section.settings.show_qty_stepper, lazy_load: true -%}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..products_to_show) -%}
            <div class="product-card">
              <div class="product-card__image-wrapper">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="product-card__content">
                <h3 class="product-card__title">Beispielprodukt {{ forloop.index }}</h3>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if show_view_all and collection != blank -%}
        <div class="featured-products__footer">
          <a href="{{ collection.url }}" class="btn btn--cta btn--arrow">
            {{ 'sections.featured_collection.view_all' | t }}
            {%- render 'icon-arrow' -%}
          </a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "header",
      "content": "Überschrift über dem Raster"
    },
    {
      "type": "checkbox",
      "id": "show_section_heading",
      "label": "Abschnitts-Überschrift anzeigen",
      "default": true,
      "info": "Empfohlen bei aktivierten Kategorie-Tabs (wie unterkonstruktion.de)."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Untertitel / Kicker"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Qualität, auf die Sie bauen können – unsere Produkte im Überblick"
    },
    {
      "type": "text",
      "id": "header_link_label",
      "label": "Rechter Link (optional)",
      "info": "z. B. „Zum Shop“"
    },
    {
      "type": "url",
      "id": "header_link_url",
      "label": "URL für rechten Link"
    },
    {
      "type": "header",
      "content": "Kategorie-Tabs"
    },
    {
      "type": "checkbox",
      "id": "show_tabs",
      "label": "Kategorie-Tabs anzeigen",
      "default": true,
      "info": "Tabs über „Kategorie-Tab“-Blöcken; jedes Tab lädt die zugewiesene Kollektion."
    },
    {
      "type": "header",
      "content": "Produkte"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Fallback-Kollektion (ohne Tab-Blöcke)",
      "info": "Wird genutzt, wenn keine Tab-Blöcke definiert sind oder Tabs aus sind."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Anzahl Produkte pro Tab / Raster",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_qty_stepper",
      "label": "Mengen-Stepper anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "„Alle ansehen“ unter jedem Tab",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "alternate_bg",
      "label": "Alternativer Hintergrund",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "category_tab",
      "name": "Kategorie-Tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tab-Label",
          "info": "Leer = Titel der Kollektion"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Kollektion"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "blocks": [
        { "type": "category_tab", "settings": { "label": "Alle" } },
        { "type": "category_tab", "settings": { "label": "Unterkonstruktion" } },
        { "type": "category_tab", "settings": { "label": "Solarmodule" } },
        { "type": "category_tab", "settings": { "label": "Wechselrichter" } },
        { "type": "category_tab", "settings": { "label": "Zubehör" } }
      ]
    }
  ]
}
{% endschema %}

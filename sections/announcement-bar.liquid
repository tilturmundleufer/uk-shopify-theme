{%- comment -%}
  Announcement Bar Section
  Multi-column layout with icons like unterkonstruktion.de
{%- endcomment -%}

{%- if section.settings.show_announcement -%}
  <div 
    class="announcement-bar" 
    style="
      --announcement-bg: {{ section.settings.background_color }};
      --announcement-text: {{ section.settings.text_color }};
      --announcement-accent: {{ section.settings.accent_color }};
    "
  >
    <div class="page-width">
      <div class="announcement-bar__content">
        {%- comment -%} Left items {%- endcomment -%}
        <div class="announcement-bar__left">
          {%- if section.settings.text != blank -%}
            <div class="announcement-bar__item">
              <svg class="announcement-bar__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <span>{{ section.settings.text }}</span>
            </div>
          {%- endif -%}
          
          {%- if section.settings.text_2 != blank -%}
            <div class="announcement-bar__item announcement-bar__item--accent">
              <svg class="announcement-bar__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                <line x1="7" y1="7" x2="7.01" y2="7"></line>
              </svg>
              <span>{{ section.settings.text_2 }}</span>
            </div>
          {%- endif -%}
        </div>
        
        {%- comment -%} Right items - Contact {%- endcomment -%}
        <div class="announcement-bar__right">
          {%- if settings.contact_phone != blank -%}
            <a href="tel:{{ settings.contact_phone | remove: ' ' }}" class="announcement-bar__link">
              {%- render 'icon-phone' -%}
              <span>{{ settings.contact_phone }}</span>
            </a>
          {%- endif -%}
          
          {%- if settings.contact_email != blank -%}
            <a href="mailto:{{ settings.contact_email }}" class="announcement-bar__link">
              {%- render 'icon-mail' -%}
              <span>{{ settings.contact_email }}</span>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "class": "section-announcement",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Announcement anzeigen",
      "default": true
    },
    {
      "type": "header",
      "content": "Texte"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text 1",
      "default": "Tagesaktuelle Bestpreise"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text 2 (Akzentfarbe)",
      "default": "Ganzjährige Top-Deals!"
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Hintergrundfarbe",
      "default": "#1a2744"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akzentfarbe",
      "default": "#f5a623"
    }
  ]
}
{% endschema %}

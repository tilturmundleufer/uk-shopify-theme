{%- comment -%}
  Announcement Bar Section
{%- endcomment -%}

{%- if section.settings.show_announcement -%}
  <div class="announcement-bar" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
    <div class="page-width">
      <div class="announcement-bar__content">
        {%- if section.settings.text != blank -%}
          <p class="announcement-bar__text">
            {%- if section.settings.link != blank -%}
              <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
            {%- else -%}
              {{ section.settings.text }}
            {%- endif -%}
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "class": "section-announcement",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Announcement anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Tagesaktuelle Bestpreise - Ganzjährige Top-Deals!"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Hintergrundfarbe",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}

{%- comment -%}
  Header Section
  Inspired by unterkonstruktion.de
  Includes: Topbar with secondary links, Main header with search, Navigation bar
{%- endcomment -%}

{%- liquid
  assign logo = section.settings.logo
  assign logo_width = section.settings.logo_width
  assign menu = section.settings.menu
  assign show_topbar = section.settings.show_topbar
  assign cta_text = section.settings.cta_text
  assign cta_url = section.settings.cta_url
  assign sticky_header = section.settings.sticky_header
  assign show_account = section.settings.show_account_link
  assign account_label = section.settings.account_label
  assign account_url = section.settings.account_url
  if account_url == blank
    assign account_url = routes.account_login_url
  endif
-%}

<header class="header{% if sticky_header %} header--sticky{% endif %}" data-header>
  {%- comment -%} Top Bar with secondary links {%- endcomment -%}
  {%- if show_topbar -%}
    <div class="topbar">
      <div class="page-width">
        <div class="topbar__inner">
          <nav class="topbar__nav" aria-label="{{ 'sections.header.secondary_menu' | t }}">
            {%- for block in section.blocks -%}
              {%- if block.type == 'topbar_link' -%}
                <a href="{{ block.settings.link }}" class="topbar__nav-link">
                  {{ block.settings.label }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        </div>
      </div>
    </div>
  {%- endif -%}
  
  {%- comment -%} Main Header {%- endcomment -%}
  <div class="header__main">
    <div class="page-width">
      <div class="header__inner">
        {%- comment -%} Logo {%- endcomment -%}
        <div class="header__logo">
          <a href="{{ routes.root_url }}" class="header__logo-link">
            {%- if logo != blank -%}
              <img
                src="{{ logo | image_url: width: logo_width | times: 2 }}"
                alt="{{ shop.name }}"
                class="header__logo-img"
                width="{{ logo_width }}"
                height="{{ logo_width | divided_by: logo.aspect_ratio | round }}"
                loading="eager"
              >
            {%- else -%}
              <span class="header__logo-text">{{ shop.name }}</span>
            {%- endif -%}
          </a>
        </div>
        
        {%- comment -%} Search Bar {%- endcomment -%}
        <div class="header__search">
          <form action="{{ routes.search_url }}" method="get" class="header__search-form" role="search">
            <input type="hidden" name="type" value="product">
            {%- render 'icon-search', class: 'header__search-icon' -%}
            <input
              type="search"
              name="q"
              class="header__search-input"
              placeholder="{{ 'sections.header.search_placeholder' | t | default: 'Alle Produkte durchsuchen...' }}"
              aria-label="{{ 'sections.header.search' | t }}"
            >
          </form>
        </div>
        
        {%- comment -%} Actions {%- endcomment -%}
        <div class="header__actions">
          {%- if show_account and account_label != blank -%}
            <a href="{{ account_url }}" class="header__account-link">
              {%- render 'icon-user', class: 'header__account-icon' -%}
              <span class="header__account-text">{{ account_label }}</span>
            </a>
          {%- endif -%}
          {%- if cta_text != blank -%}
            <a href="{{ cta_url | default: '#' }}" class="btn btn--cta header__cta">
              {{ cta_text }}
            </a>
          {%- endif -%}
          
          {%- comment -%} Cart Button with text (Desktop) {%- endcomment -%}
          <a href="{{ routes.cart_url }}" class="header__cart-btn" aria-label="{{ 'sections.header.cart' | t }}">
            {%- render 'icon-cart' -%}
            <span>{{ 'sections.header.cart_text' | t | default: 'Warenkorb' }}</span>
          </a>
          
          {%- comment -%} Cart Icon (Mobile) {%- endcomment -%}
          <a href="{{ routes.cart_url }}" class="header__action-btn header__cart-icon-mobile" aria-label="{{ 'sections.header.cart' | t }}">
            {%- render 'icon-cart' -%}
            <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
          </a>
          
          <button 
            type="button" 
            class="header__action-btn header__menu-toggle" 
            aria-label="{{ 'accessibility.menu' | t }}"
            aria-expanded="false"
            aria-controls="mobile-menu"
            data-menu-toggle
          >
            {%- render 'icon-menu' -%}
          </button>
        </div>
      </div>
    </div>
  </div>
  
  {%- comment -%} Main Navigation Bar (Desktop) {%- endcomment -%}
  <div class="header__nav-bar">
    <div class="page-width">
      <nav class="header__nav" aria-label="{{ 'sections.header.menu' | t }}">
        {%- for link in linklists[menu].links -%}
          <div class="header__nav-item">
            {%- if link.links != blank -%}
              <button 
                class="header__nav-link" 
                aria-expanded="false"
                aria-controls="dropdown-{{ forloop.index }}"
              >
                {%- comment -%} Category icons based on title {%- endcomment -%}
                {%- case link.title | downcase -%}
                  {%- when 'unterkonstruktion' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  {%- when 'solarmodule' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                  {%- when 'wechselrichter' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="10" rx="2"/><line x1="6" y1="12" x2="10" y2="12"/><circle cx="16" cy="12" r="2"/></svg>
                  {%- when 'batteriespeicher' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="18" height="10" rx="2"/><line x1="22" y1="11" x2="22" y2="13"/><line x1="6" y1="11" x2="6" y2="13"/><line x1="10" y1="11" x2="10" y2="13"/><line x1="14" y1="11" x2="14" y2="13"/></svg>
                  {%- when 'zubehör' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                  {%- else -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/></svg>
                {%- endcase -%}
                {{ link.title }}
                {%- render 'icon-chevron', class: 'chevron-icon' -%}
              </button>
              <div class="header__dropdown" id="dropdown-{{ forloop.index }}">
                {%- for child_link in link.links -%}
                  <a href="{{ child_link.url }}" class="header__dropdown-link">
                    {{ child_link.title }}
                  </a>
                {%- endfor -%}
              </div>
            {%- else -%}
              <a href="{{ link.url }}" class="header__nav-link{% if link.active %} header__nav-link--active{% endif %}">
                {%- case link.title | downcase -%}
                  {%- when 'unterkonstruktion' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  {%- when 'solarmodule' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                  {%- when 'wechselrichter' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="10" rx="2"/><line x1="6" y1="12" x2="10" y2="12"/><circle cx="16" cy="12" r="2"/></svg>
                  {%- when 'batteriespeicher' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="18" height="10" rx="2"/><line x1="22" y1="11" x2="22" y2="13"/><line x1="6" y1="11" x2="6" y2="13"/><line x1="10" y1="11" x2="10" y2="13"/><line x1="14" y1="11" x2="14" y2="13"/></svg>
                  {%- when 'zubehör' -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                  {%- else -%}
                    <svg class="header__nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/></svg>
                {%- endcase -%}
                {{ link.title }}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </nav>
    </div>
  </div>
  
  {%- comment -%} Mobile Menu Drawer {%- endcomment -%}
  <div class="mobile-menu" id="mobile-menu" data-mobile-menu aria-hidden="true">
    <div class="mobile-menu__header">
      <div class="header__logo">
        <a href="{{ routes.root_url }}" class="header__logo-link">
          {%- if logo != blank -%}
            <img
              src="{{ logo | image_url: width: logo_width | times: 2 }}"
              alt="{{ shop.name }}"
              class="header__logo-img"
              width="{{ logo_width }}"
              height="{{ logo_width | divided_by: logo.aspect_ratio | round }}"
            >
          {%- else -%}
            <span class="header__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>
      <button 
        type="button" 
        class="mobile-menu__close" 
        aria-label="{{ 'accessibility.close' | t }}"
        data-menu-close
      >
        {%- render 'icon-close' -%}
      </button>
    </div>
    
    <div class="mobile-menu__content">
      {%- comment -%} Mobile Search {%- endcomment -%}
      <form action="{{ routes.search_url }}" method="get" class="mobile-menu__search" role="search">
        <input type="hidden" name="type" value="product">
        <input
          type="search"
          name="q"
          class="header__search-input"
          placeholder="{{ 'sections.header.search_placeholder' | t | default: 'Produkte durchsuchen...' }}"
          aria-label="{{ 'sections.header.search' | t }}"
        >
      </form>

      {%- if show_account and account_label != blank -%}
        <a href="{{ account_url }}" class="mobile-menu__account">
          {%- render 'icon-user', class: 'mobile-menu__account-icon' -%}
          {{ account_label }}
        </a>
      {%- endif -%}
      
      <nav class="mobile-menu__nav" aria-label="{{ 'sections.header.menu' | t }}">
        {%- for link in linklists[menu].links -%}
          <div class="mobile-menu__nav-item">
            {%- if link.links != blank -%}
              <button 
                class="mobile-menu__nav-link" 
                aria-expanded="false"
                data-submenu-toggle
              >
                {{ link.title }}
                {%- render 'icon-chevron' -%}
              </button>
              <div class="mobile-menu__subnav" data-submenu hidden>
                {%- for child_link in link.links -%}
                  <a href="{{ child_link.url }}" class="mobile-menu__subnav-link">
                    {{ child_link.title }}
                  </a>
                {%- endfor -%}
              </div>
            {%- else -%}
              <a href="{{ link.url }}" class="mobile-menu__nav-link">
                {{ link.title }}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </nav>
      
      <div class="mobile-menu__contact">
        {%- if settings.contact_phone != blank -%}
          <a href="tel:{{ settings.contact_phone | remove: ' ' }}" class="mobile-menu__contact-link">
            {%- render 'icon-phone' -%}
            <span>{{ settings.contact_phone }}</span>
          </a>
        {%- endif -%}
        {%- if settings.contact_email != blank -%}
          <a href="mailto:{{ settings.contact_email }}" class="mobile-menu__contact-link">
            {%- render 'icon-mail' -%}
            <span>{{ settings.contact_email }}</span>
          </a>
        {%- endif -%}
      </div>
      
      {%- if cta_text != blank -%}
        <a href="{{ cta_url | default: '#' }}" class="btn btn--cta btn--full mobile-menu__cta">
          {{ cta_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
  
  <div class="header-overlay" data-header-overlay></div>
</header>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo-Breite",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Hauptmenü",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_topbar",
      "label": "Topbar anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky Header",
      "default": true
    },
    {
      "type": "header",
      "content": "Kundenkonto"
    },
    {
      "type": "checkbox",
      "id": "show_account_link",
      "label": "Link „Mein Konto“ anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Konto-Text",
      "default": "Mein Konto"
    },
    {
      "type": "url",
      "id": "account_url",
      "label": "Konto-Link",
      "info": "Leer lassen für Shopify Login (/account/login)"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button-Text",
      "default": "Zum Konfigurator"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button-Link"
    }
  ],
  "blocks": [
    {
      "type": "topbar_link",
      "name": "Topbar Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Text",
          "default": "Kontakt"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "topbar_link", "settings": { "label": "Kontakt" } },
        { "type": "topbar_link", "settings": { "label": "Über Uns" } },
        { "type": "topbar_link", "settings": { "label": "FAQ" } }
      ]
    }
  ]
}
{% endschema %}

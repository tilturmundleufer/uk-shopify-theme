{%- comment -%}
  Contact Form Section
{%- endcomment -%}

<section class="contact-form-section section" id="contact-{{ section.id }}">
  <div class="page-width">
    <div class="contact-form-wrapper">
      <div class="contact-form__info">
        {%- if section.settings.heading != blank -%}
          <h2 class="contact-form__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        
        {%- if section.settings.text != blank -%}
          <div class="contact-form__text rte">
            {{ section.settings.text }}
          </div>
        {%- endif -%}
        
        <div class="contact-form__details">
          {%- if settings.contact_phone != blank -%}
            <a href="tel:{{ settings.contact_phone | remove: ' ' }}" class="contact-form__link">
              {%- render 'icon-phone' -%}
              {{ settings.contact_phone }}
            </a>
          {%- endif -%}
          {%- if settings.contact_email != blank -%}
            <a href="mailto:{{ settings.contact_email }}" class="contact-form__link">
              {%- render 'icon-mail' -%}
              {{ settings.contact_email }}
            </a>
          {%- endif -%}
        </div>
      </div>
      
      <div class="contact-form__form-wrapper">
        {%- form 'contact', id: 'ContactForm', class: 'contact-form__form' -%}
          {%- if form.posted_successfully? -%}
            <div class="contact-form__success">
              <p>{{ 'contact.form.success' | t }}</p>
            </div>
          {%- endif -%}
          
          {%- if form.errors -%}
            <div class="contact-form__errors">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}
          
          <div class="contact-form__fields">
            <div class="contact-form__field">
              <label for="ContactForm-name" class="contact-form__label">{{ 'contact.form.name' | t }} *</label>
              <input
                type="text"
                id="ContactForm-name"
                name="contact[name]"
                class="contact-form__input"
                value="{{ form.name }}"
                required
              >
            </div>
            
            <div class="contact-form__field">
              <label for="ContactForm-email" class="contact-form__label">{{ 'contact.form.email' | t }} *</label>
              <input
                type="email"
                id="ContactForm-email"
                name="contact[email]"
                class="contact-form__input"
                value="{{ form.email }}"
                autocapitalize="off"
                required
              >
            </div>
            
            <div class="contact-form__field">
              <label for="ContactForm-phone" class="contact-form__label">{{ 'contact.form.phone' | t }}</label>
              <input
                type="tel"
                id="ContactForm-phone"
                name="contact[phone]"
                class="contact-form__input"
                value="{{ form.phone }}"
              >
            </div>
            
            <div class="contact-form__field contact-form__field--full">
              <label for="ContactForm-message" class="contact-form__label">{{ 'contact.form.message' | t }} *</label>
              <textarea
                id="ContactForm-message"
                name="contact[body]"
                class="contact-form__textarea"
                rows="6"
                required
              >{{ form.body }}</textarea>
            </div>
          </div>
          
          <button type="submit" class="btn btn--primary btn--lg">
            {{ 'contact.form.submit' | t }}
          </button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

<style>
  .contact-form-wrapper {
    display: grid;
    gap: var(--spacing-2xl);
    max-width: 1000px;
    margin: 0 auto;
  }
  
  @media (min-width: 990px) {
    .contact-form-wrapper {
      grid-template-columns: 1fr 1.5fr;
    }
  }
  
  .contact-form__heading {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--spacing-md);
  }
  
  .contact-form__text {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-lg);
  }
  
  .contact-form__details {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
  
  .contact-form__link {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-weight: 600;
    color: var(--color-primary);
  }
  
  .contact-form__link svg {
    width: 20px;
    height: 20px;
  }
  
  .contact-form__form-wrapper {
    padding: var(--spacing-xl);
    background-color: #f9fafb;
    border-radius: var(--radius-lg);
  }
  
  .contact-form__success {
    padding: var(--spacing-md);
    background-color: rgba(34, 197, 94, 0.1);
    border-radius: var(--radius-md);
    color: var(--color-success);
    margin-bottom: var(--spacing-lg);
  }
  
  .contact-form__errors {
    padding: var(--spacing-md);
    background-color: rgba(239, 68, 68, 0.1);
    border-radius: var(--radius-md);
    color: var(--color-error);
    margin-bottom: var(--spacing-lg);
  }
  
  .contact-form__fields {
    display: grid;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }
  
  @media (min-width: 750px) {
    .contact-form__fields {
      grid-template-columns: 1fr 1fr;
    }
    
    .contact-form__field--full {
      grid-column: 1 / -1;
    }
  }
  
  .contact-form__label {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }
  
  .contact-form__input,
  .contact-form__textarea {
    width: 100%;
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: var(--font-size-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background-color: #fff;
  }
  
  .contact-form__input:focus,
  .contact-form__textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }
  
  .contact-form__textarea {
    resize: vertical;
    min-height: 120px;
  }
</style>

{% schema %}
{
  "name": "Kontaktformular",
  "tag": "section",
  "class": "section-contact-form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Kontaktieren Sie uns"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Haben Sie Fragen? Wir helfen Ihnen gerne weiter!</p>"
    }
  ],
  "presets": [
    {
      "name": "Kontaktformular"
    }
  ]
}
{% endschema %}

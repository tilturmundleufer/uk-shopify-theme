{%- comment -%}
  Hero Section
  Inspired by unterkonstruktion.de with full-width background image
{%- endcomment -%}

{{ 'section-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign primary_cta_text = section.settings.primary_cta_text
  assign primary_cta_url = section.settings.primary_cta_url
  assign secondary_cta_text = section.settings.secondary_cta_text
  assign secondary_cta_url = section.settings.secondary_cta_url
  assign background_image = section.settings.background_image
  assign emphasis_word = section.settings.heading_emphasis_word | strip

  assign cta_box_heading = section.settings.cta_box_heading
  assign cta_box_image = section.settings.cta_box_image
  assign cta_box_text = section.settings.cta_box_text
  assign cta_box_url = section.settings.cta_box_url
  assign cta_box_button_text = section.settings.cta_box_button_text
-%}

<section class="hero" id="hero-{{ section.id }}"{% if background_image != blank %} style="background-image: url('{{ background_image | image_url: width: 1920 }}');"{% endif %}>
  <div class="hero__overlay"></div>
  <div class="page-width">
    <div class="hero__inner">
      <div class="hero__content">
        {%- if eyebrow != blank -%}
          <span class="eyebrow hero__eyebrow">{{ eyebrow }}</span>
        {%- endif -%}

        {%- if heading != blank -%}
          <h1 class="hero__title">
            {%- if emphasis_word != blank and heading contains emphasis_word -%}
              {%- assign h_parts = heading | split: emphasis_word -%}
              {{ h_parts[0] }}<strong>{{ emphasis_word }}</strong>{{ h_parts[1] }}
            {%- else -%}
              {{ heading }}
            {%- endif -%}
          </h1>
        {%- endif -%}
        
        {%- if subheading != blank -%}
          <p class="hero__subtitle">{{ subheading }}</p>
        {%- endif -%}
        
        <div class="hero__actions">
          {%- if primary_cta_text != blank -%}
            <a href="{{ primary_cta_url | default: '#' }}" class="btn btn--white btn--lg">
              {{ primary_cta_text }}
            </a>
          {%- endif -%}
          
          {%- if secondary_cta_text != blank -%}
            <a href="{{ secondary_cta_url | default: '#' }}" class="btn btn--outline-white btn--lg btn--arrow">
              {{ secondary_cta_text }}
              {%- render 'icon-arrow' -%}
            </a>
          {%- endif -%}
        </div>
      </div>
      
      {%- if section.settings.show_cta_box -%}
        <div class="hero__cta-box">
          <div class="hero__cta-box-inner">
            {%- if cta_box_heading != blank -%}
              <h2 class="hero__cta-box-title">{{ cta_box_heading }}</h2>
            {%- endif -%}
            
            {%- if cta_box_image != blank -%}
              <div class="hero__cta-box-image">
                <img
                  src="{{ cta_box_image | image_url: width: 300 }}"
                  alt="{{ cta_box_heading }}"
                  width="200"
                  height="200"
                  loading="eager"
                >
                {%- if cta_box_text != blank -%}
                  <span class="hero__cta-box-label">{{ cta_box_text }}</span>
                {%- endif -%}
              </div>
            {%- else -%}
              <div class="hero__cta-box-icon" aria-hidden="true">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35">
                  <rect x="3" y="3" width="7" height="7" rx="1"/>
                  <rect x="14" y="3" width="7" height="7" rx="1"/>
                  <rect x="3" y="14" width="7" height="7" rx="1"/>
                  <rect x="14" y="14" width="7" height="7" rx="1"/>
                </svg>
              </div>
            {%- endif -%}
            
            <a href="{{ cta_box_url | default: '#' }}" class="btn btn--cta btn--lg btn--full btn--arrow">
              {{ cta_box_button_text | default: 'Jetzt planen' }}
              {%- render 'icon-arrow' -%}
            </a>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Unterkonstruktion"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Wir haben alles für Ihr nächstes Solarprojekt"
    },
    {
      "type": "text",
      "id": "heading_emphasis_word",
      "label": "Hervorgehobenes Wort in der Überschrift",
      "default": "alles",
      "info": "Wird fett/gelb dargestellt, wenn es exakt in der Überschrift vorkommt."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Untertitel",
      "default": "Ihr zuverlässiger Partner für PV-Unterkonstruktion und mehr. Von Eigenheim bis Großprojekt - wir haben es auf Lager!"
    },
    {
      "type": "header",
      "content": "Primärer CTA"
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Button-Text",
      "default": "Zum Konfigurator"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Button-Link"
    },
    {
      "type": "header",
      "content": "Sekundärer CTA"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Button-Text",
      "default": "Alle Produkte"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Button-Link"
    },
    {
      "type": "header",
      "content": "Hintergrundbild"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Hintergrundbild"
    },
    {
      "type": "header",
      "content": "CTA-Box (rechts)"
    },
    {
      "type": "checkbox",
      "id": "show_cta_box",
      "label": "CTA-Box anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_box_heading",
      "label": "Überschrift",
      "default": "Module planen leicht gemacht!"
    },
    {
      "type": "image_picker",
      "id": "cta_box_image",
      "label": "Bild/Icon"
    },
    {
      "type": "text",
      "id": "cta_box_text",
      "label": "Bildunterschrift",
      "default": "Solarmodul"
    },
    {
      "type": "url",
      "id": "cta_box_url",
      "label": "Link (CTA-Box Button)"
    },
    {
      "type": "text",
      "id": "cta_box_button_text",
      "label": "Button-Text (CTA-Box)",
      "default": "Jetzt planen"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}

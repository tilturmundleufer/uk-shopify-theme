{%- comment -%}
  Hero Section
  Inspired by unterkonstruktion.de with full-width background image
{%- endcomment -%}

{{ 'section-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign primary_cta_text = section.settings.primary_cta_text
  assign primary_cta_url = section.settings.primary_cta_url
  assign secondary_cta_text = section.settings.secondary_cta_text
  assign secondary_cta_url = section.settings.secondary_cta_url
  assign background_image = section.settings.background_image
  
  assign cta_box_heading = section.settings.cta_box_heading
  assign cta_box_image = section.settings.cta_box_image
  assign cta_box_text = section.settings.cta_box_text
  assign cta_box_url = section.settings.cta_box_url
-%}

<section class="hero" id="hero-{{ section.id }}"{% if background_image != blank %} style="background-image: url('{{ background_image | image_url: width: 1920 }}');"{% endif %}>
  <div class="hero__overlay"></div>
  <div class="page-width">
    <div class="hero__inner">
      <div class="hero__content">
        {%- if heading != blank -%}
          <h1 class="hero__title">
            {%- assign words = heading | split: ' ' -%}
            {%- for word in words -%}
              {%- if forloop.index == 3 -%}<strong>{% endif -%}
              {{ word }}{% unless forloop.last %} {% endunless %}
              {%- if forloop.index == 3 -%}</strong>{% endif -%}
            {%- endfor -%}
          </h1>
        {%- endif -%}
        
        {%- if subheading != blank -%}
          <p class="hero__subtitle">{{ subheading }}</p>
        {%- endif -%}
        
        <div class="hero__actions">
          {%- if primary_cta_text != blank -%}
            <a href="{{ primary_cta_url | default: '#' }}" class="btn btn--white btn--lg">
              {{ primary_cta_text }}
            </a>
          {%- endif -%}
          
          {%- if secondary_cta_text != blank -%}
            <a href="{{ secondary_cta_url | default: '#' }}" class="btn btn--outline-white btn--lg btn--arrow">
              {{ secondary_cta_text }}
              {%- render 'icon-arrow' -%}
            </a>
          {%- endif -%}
        </div>
      </div>
      
      {%- if section.settings.show_cta_box -%}
        <div class="hero__cta-box">
          <div class="hero__cta-box-inner">
            {%- if cta_box_heading != blank -%}
              <h2 class="hero__cta-box-title">{{ cta_box_heading }}</h2>
            {%- endif -%}
            
            {%- if cta_box_image != blank -%}
              <div class="hero__cta-box-image">
                <img
                  src="{{ cta_box_image | image_url: width: 300 }}"
                  alt="{{ cta_box_heading }}"
                  width="200"
                  height="200"
                  loading="eager"
                >
                {%- if cta_box_text != blank -%}
                  <span class="hero__cta-box-label">{{ cta_box_text }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
            
            <a href="{{ cta_box_url | default: '#' }}" class="btn btn--cta btn--lg btn--full btn--arrow">
              {{ primary_cta_text | default: 'Zum Konfigurator' }}
              {%- render 'icon-arrow' -%}
            </a>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Wir haben alles für Ihr nächstes Solarprojekt"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Untertitel",
      "default": "Ihr zuverlässiger Partner für PV-Unterkonstruktion und mehr. Von Eigenheim bis Großprojekt - wir haben es auf Lager!"
    },
    {
      "type": "header",
      "content": "Primärer CTA"
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Button-Text",
      "default": "Zum Konfigurator"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Button-Link"
    },
    {
      "type": "header",
      "content": "Sekundärer CTA"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Button-Text",
      "default": "Alle Produkte"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Button-Link"
    },
    {
      "type": "header",
      "content": "Hintergrundbild"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Hintergrundbild"
    },
    {
      "type": "header",
      "content": "CTA-Box (rechts)"
    },
    {
      "type": "checkbox",
      "id": "show_cta_box",
      "label": "CTA-Box anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_box_heading",
      "label": "Überschrift",
      "default": "Jetzt Unterkonstruktion selbst konfigurieren!"
    },
    {
      "type": "image_picker",
      "id": "cta_box_image",
      "label": "Bild/Icon"
    },
    {
      "type": "text",
      "id": "cta_box_text",
      "label": "Bildunterschrift",
      "default": "Solarmodul"
    },
    {
      "type": "url",
      "id": "cta_box_url",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}

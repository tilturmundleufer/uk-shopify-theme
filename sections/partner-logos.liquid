{%- comment -%}
  Partner Logos Section
  Scrolling logo strip
{%- endcomment -%}

<section class="partner-logos section" id="partners-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-header text-center">
        {%- if section.settings.subheading != blank -%}
          <p class="section-subtitle text-sm text-muted uppercase">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    
    <div class="partner-logos__track{% if section.settings.enable_scroll %} partner-logos__track--scroll{% endif %}">
      <div class="partner-logos__list">
        {%- for block in section.blocks -%}
          {%- if block.settings.logo != blank -%}
            <div class="partner-logos__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" target="_blank" rel="noopener">
              {%- endif -%}
                <img
                  src="{{ block.settings.logo | image_url: width: 200 }}"
                  alt="{{ block.settings.name | default: 'Partner' | escape }}"
                  loading="lazy"
                  width="{{ block.settings.logo.width }}"
                  height="{{ block.settings.logo.height }}"
                >
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      
      {%- if section.settings.enable_scroll -%}
        <div class="partner-logos__list" aria-hidden="true">
          {%- for block in section.blocks -%}
            {%- if block.settings.logo != blank -%}
              <div class="partner-logos__item">
                <img
                  src="{{ block.settings.logo | image_url: width: 200 }}"
                  alt=""
                  loading="lazy"
                >
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .partner-logos {
    overflow: hidden;
  }
  
  .partner-logos__track {
    display: flex;
    gap: var(--spacing-xl);
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .partner-logos__track--scroll {
    flex-wrap: nowrap;
    justify-content: flex-start;
    animation: scroll 30s linear infinite;
  }
  
  .partner-logos__track--scroll:hover {
    animation-play-state: paused;
  }
  
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  .partner-logos__list {
    display: flex;
    gap: var(--spacing-xl);
    align-items: center;
    flex-shrink: 0;
  }
  
  .partner-logos__item {
    flex-shrink: 0;
  }
  
  .partner-logos__item img {
    height: 40px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: filter var(--transition-base), opacity var(--transition-base);
  }
  
  .partner-logos__item:hover img {
    filter: grayscale(0%);
    opacity: 1;
  }
  
  @media (min-width: 750px) {
    .partner-logos__item img {
      height: 50px;
      max-width: 150px;
    }
  }
</style>

{% schema %}
{
  "name": "Partner Logos",
  "tag": "section",
  "class": "section-partner-logos",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Untertitel",
      "default": "Unsere Partner"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift"
    },
    {
      "type": "checkbox",
      "id": "enable_scroll",
      "label": "Auto-Scroll aktivieren",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Firmenname"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partner Logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}

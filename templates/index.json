ener('input', (e) => {\n      e.stopPropagation();\n      video.volume = parseFloat(vol.value);\n      video.muted = video.volume === 0;\n      updateMuteIcons();\n    });\n\n    seek.addEventListener('input', (e) => {\n      e.stopPropagation();\n      if (!video.duration) return;\n      const t = (parseFloat(seek.value) / 100) * video.duration;\n      video.currentTime = t;\n    });\n\n    // Fullscreen (Desktop + iOS Safari Fallback)\n    function inFullscreen() {\n      return !!(document.fullscreenElement || document.webkitFullscreenElement || document.msFullscreenElement);\n    }\n    function updateFsIcons() {\n      const on = inFullscreen();\n      fsEnterIcon.style.display = on ? 'none' : '';\n      fsExitIcon.style.display = on ? '' : 'none';\n      root.classList.toggle('is-fullscreen', on);\n    }\n    async function enterFullscreen() {\n      if (typeof video.webkitEnterFullscreen === 'function' && /iPhone|iPad|iPod/i.test(navigator.userAgent)) {\n        try {\n          video.webkitEnterFullscreen();\n        } catch (e) {}\n        return;\n      }\n      const el = root.requestFullscreen ? root : video.requestFullscreen ? video : root;\n      try {\n        if (el.requestFullscreen) await el.requestFullscreen();\n        else if (el.webkitRequestFullscreen) await el.webkitRequestFullscreen();\n        else if (el.msRequestFullscreen) await el.msRequestFullscreen();\n      } catch (e) {}\n    }\n    async function exitFullscreen() {\n      try {\n        if (document.exitFullscreen) await document.exitFullscreen();\n        else if (document.webkitExitFullscreen) await document.webkitExitFullscreen();\n        else if (document.msExitFullscreen) await document.msExitFullscreen();\n      } catch (e) {}\n    }\n    btnFS.addEventListener('click', (e) => {\n      e.stopPropagation();\n      inFullscreen() ? exitFullscreen() : enterFullscreen();\n    });\n    ['fullscreenchange', 'webkitfullscreenchange', 'msfullscreenchange'].forEach((evt) => {\n      document.addEventListener(evt, updateFsIcons);\n    });\n    updateFsIcons();\n\n    // Hover/Touch: Controls kurz einblenden\n    root.addEventListener(\n      'mousemove',\n      () => {\n        if (root.classList.contains('is-playing')) showControlsTemp();\n      },\n      { passive: true },\n    );\n    root.addEventListener(\n      'touchstart',\n      () => {\n        if (root.classList.contains('is-playing')) showControlsTemp();\n      },\n      { passive: true },\n    );\n\n    // Root-Click: nur wenn gemutet → Ton an + ab Anfang starten\n    root.addEventListener('click', (e) => {\n      // Klicks auf Controls ignorieren\n      const insideControls = e.target.closest('[data-uk-vp-chrome], [data-uk-vp-bigplay], [data-uk-vp-full]');\n      if (insideControls) return;\n\n      // Reagiere nur, wenn aktuell gemutet\n      if (video.muted) {\n        video.muted = false; // Ton an\n        updateMuteIcons();\n        try {\n          video.currentTime = 0;\n        } catch (_) {}\n        video.play().catch(() => {});\n      }\n      // Wenn nicht gemutet: nichts tun (kein Restart, keine Tonänderung)\n    });\n\n    // Keyboard\n    root.tabIndex = 0;\n    root.addEventListener('keydown', (e) => {\n      if (e.target instanceof HTMLInputElement) return;\n      switch (e.key.toLowerCase()) {\n        case ' ':\n        case 'k':\n          e.preventDefault();\n          video.paused ? video.play().catch(() => {}) : video.pause();\n          break;\n        case 'm':\n          video.muted = !video.muted;\n          updateMuteIcons();\n          break;\n        case 'f':\n          btnFS.click();\n          break;\n        case 'arrowright':\n          video.currentTime = Math.min(video.duration || 0, video.currentTime + (e.shiftKey ? 10 : 5));\n          break;\n        case 'arrowleft':\n          video.currentTime = Math.max(0, video.currentTime - (e.shiftKey ? 10 : 5));\n          break;\n        case 'arrowup':\n          video.volume = Math.min(1, (video.vo
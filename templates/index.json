t btnMU = root.querySelector('[data-uk-vp-mute]');\n    const btnFS = root.querySelector('[data-uk-vp-full]');\n    const seek = root.querySelector('[data-uk-vp-seek]');\n    const vol = root.querySelector('[data-uk-vp-volume]');\n    const cur = root.querySelector('[data-uk-vp-current]');\n    const dur = root.querySelector('[data-uk-vp-duration]');\n    const bufBar = root.querySelector('[data-uk-vp-buffer]');\n    const icoPlay = btnPL.querySelector('[data-icon=\"play\"]');\n    const icoPause = btnPL.querySelector('[data-icon=\"pause\"]');\n    const icoVolOn = btnMU.querySelector('[data-icon=\"vol-on\"]');\n    const icoVolOff = btnMU.querySelector('[data-icon=\"vol-off\"]');\n    const fsEnterIcon = btnFS.querySelector('[data-icon=\"fs-enter\"]');\n    const fsExitIcon = btnFS.querySelector('[data-icon=\"fs-exit\"]');\n\n    // helpers\n    const fmt = (t) => {\n      if (!isFinite(t)) return '0:00';\n      const s = Math.max(0, Math.floor(t));\n      const m = Math.floor(s / 60),\n        r = s % 60;\n      return `${m}:${String(r).padStart(2, '0')}`;\n    };\n    const setPlaying = (on) => {\n      root.classList.toggle('is-playing', !!on);\n      root.classList.toggle('is-paused', !on);\n    };\n    const updatePlayIcons = () => {\n      const playing = !video.paused;\n      icoPlay.style.display = playing ? 'none' : '';\n      icoPause.style.display = playing ? '' : 'none';\n    };\n    const updateMuteIcons = () => {\n      const muted = video.muted || video.volume === 0;\n      icoVolOn.style.display = muted ? 'none' : '';\n      icoVolOff.style.display = muted ? '' : 'none';\n    };\n    const showControlsTemp = () => {\n      root.classList.add('show-controls');\n      clearTimeout(showControlsTemp._t);\n      showControlsTemp._t = setTimeout(() => root.classList.remove('show-controls'), 2000);\n    };\n\n    // initial\n    video.muted = true; // nötig für Autoplay\n    updateMuteIcons();\n    updatePlayIcons();\n    setPlaying(true); // Chrome blende
ffer></div>\n    </div>\n\n    <!-- Mute -->\n    <button class=\"uk-vp__btn\" type=\"button\" aria-label=\"Ton an/aus\" data-uk-vp-mute>\n      <!-- Speaker ON -->\n      <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" aria-hidden=\"true\" data-icon=\"vol-on\">\n        <path d=\"M5 9v6h4l5 4V5l-5 4H5z\" fill=\"currentColor\"></path>\n        <path d=\"M16.5 8.5a4.5 4.5 0 010 7\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"></path>\n      </svg>\n      <!-- Speaker MUTED -->\n      <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" aria-hidden=\"true\" data-icon=\"vol-off\" style=\"display: none\">\n        <path d=\"M5 9v6h4l5 4V5l-5 4H5z\" fill=\"currentColor\" opacity=\".85\"></path>\n        <path d=\"M19 9l-6 6M13 9l6 6\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"></path>\n      </svg>\n    </button>\n\n    <!-- Volume -->\n    <input class=\"uk-vp__volume\" type=\"range\" min=\"0\" max=\"1\" step=\"0.05\" value=\"1\" aria-label=\"Lautstärke\" data-uk-vp-volume />\n\n    <!-- Fullscreen -->\n    <button class=\"uk-vp__btn\" type=\"button\" aria-label=\"Vollbild\" data-uk-vp-full>\n      <!-- ENTER -->\n      <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" aria-hidden=\"true\" data-icon=\"fs-enter\">\n        <path d=\"M7 14H5v5h5v-2H7v-3zm0-4h3V7h2v5H7V10zm10 9h-3v2h5v-5h-2v3zm2-14h-5v2h3v3h2V5z\" fill=\"currentColor\"></path>\n      </svg>\n      <!-- EXIT -->\n      <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" aria-hidden=\"true\" data-icon=\"fs-exit\" style=\"display: none\">\n        <path d=\"M9 7H7v2H5V5h4v2zm10 0h-2V5h4v4h-2V7zM7 17h2v2H5v-4h2v2zm10 0h2v-2h2v4h-4v-2z\" fill=\"currentColor\"></path>\n      </svg>\n    </button>\n  </div>\n</div>\n\n<style>\n  .uk-vp {\n    --uk-fg: #fff;\n    --uk-bg: rgba(0, 0, 0, 0.55);\n    --uk-bg-strong: rgba(0, 0, 0, 0.75);\n    --uk-border: rgba(255, 255, 255, 0.2);\n    --uk-radius: 14px;\n    --uk-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);\n    --uk-pad: clamp(10px, 2vw, 16px);\n    position: relative;\n    display: grid;\n    align-items: end;\n    width: 100%;\n    margin: 0 auto;\n    border-radius: var(--uk-radius);\n    overflow: hidden;\n    box-shadow: var(--uk-shadow);\n    background: #000;\n    color: var(--uk-fg);\n  }\n  .uk-vp__video {\n    width: 100%;\n    display: block;\n    aspect-ratio: 16/9;\n    background: #000;\n  }\n\n  /* Big Play */\n  .uk-vp__bigplay {\n    position: absolute;\n    inset: 0;\n    margin: auto;\n    width: clamp(64px, 9vw, 96px);\n    height: clamp(64px, 9vw, 96px);\n    border-radius: 50%;\n    border: 1px solid var(--uk-border);\n    color: var(--uk-fg);\n    background: var(--uk-bg);\n    backdrop-filter: blur(6px);\n    -webkit-backdrop-filter: blur(6px);\n    display: grid;\n    place-items: center;\n    cursor: pointer;\n    transition:\n      background 0.2s ease,\n      transform 0.08s ease,\n      opacity 0.2s ease;\n  }\n  .uk-vp__bigplay:hover {\n    background: var(--uk-bg-strong);\n  }\n\n  /* Controls */\n  .uk-vp__chrome {\n    position: absolute;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    display: grid;\n    grid-template-columns: auto auto 1fr auto auto auto;\n    align-items: center;\n    gap: 10px;\n    padding: var(--uk-pad);\n    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.35) 30%, rgba(0, 0, 0, 0.6) 100%);\n    transition:\n      opacity 0.2s ease,\n      visibility 0.2s ease;\n  }\n  .uk-vp__btn {\n    appearance: none;\n    border: 1px solid var(--uk-border);\n    background: var(--uk-bg);\n    color: var(--uk-fg);\n    border-radius: 999px;\n    padding: 6px 10px;\n    cursor: pointer;\n    line-height: 1;\n    display: inline-grid;\n    place-items: center;\n  }\n  .uk-vp__btn:hover {\n    background: var(--uk-bg-strong);\n  }\n\n  .uk-vp__time {\n    font-variant-numeric: tabular-nums;\n    font-size: 14px;\n    opacity: 0.95;\n    white-space: nowrap;\n  }\n\n  .uk-vp__track {\n    position: re